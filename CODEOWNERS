# Code ownership for Jankurai.
# Routes pull-request review attention to the right people. Fill in handles
# before turning on "Require review from Code Owners" in GitHub branch
# protection (see docs/branch-protection.md).
#
# Order matters: later patterns override earlier ones for the same path.

# Default: any change requires a maintainer review.
*                                       @neverhuman/maintainers

# Audit engine and language detectors are the highest-trust surface.
/crates/jankurai/src/audit/             @neverhuman/maintainers
/crates/jankurai/src/audit/language_rules/ @neverhuman/maintainers
/crates/jankurai/src/audit/analyzers/   @neverhuman/maintainers
/crates/jankurai/src/boundaries/        @neverhuman/maintainers

# Standard, baselines, and release coordination.
/agent/JANKURAI_STANDARD.md             @neverhuman/maintainers
/agent/baselines/                       @neverhuman/maintainers
/agent/standard-version.toml            @neverhuman/maintainers
/VERSION                                @neverhuman/maintainers
/CHANGELOG.md                           @neverhuman/maintainers

# CI/CD, release automation, and security configuration.
/.github/                               @neverhuman/maintainers
/.pre-commit-config.yaml                @neverhuman/maintainers
/scripts/                               @neverhuman/maintainers
/.gitleaks.toml                         @neverhuman/maintainers
/SECURITY.md                            @neverhuman/maintainers

# Paper and public documentation.
/paper/                                 @neverhuman/maintainers
/docs/                                  @neverhuman/maintainers
/README.md                              @neverhuman/maintainers
