#!/usr/bin/env bash
# Mandatory pre-push gate. Runs the same script jankurai.yml#test-matrix
# runs, so it is impossible to push code that will redden CI's fmt /
# clippy / test / test-surface checks. To skip in an emergency, set
# JANKURAI_SKIP_PREPUSH=1 — every such bypass should land in an
# incident note.
set -euo pipefail

if [[ "${JANKURAI_SKIP_PREPUSH:-0}" == "1" ]]; then
  printf '\033[1;33m!! JANKURAI_SKIP_PREPUSH=1 set — skipping local CI gate\033[0m\n' >&2
  exit 0
fi

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

printf '\033[1;36m==> pre-push: ops/ci/quality-gates.sh\033[0m\n'
bash ops/ci/quality-gates.sh
