{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-native-rust.dev/schemas/vrc-plan.schema.json",
  "title": "Validation Radius Contract Plan",
  "type": "object",
  "required": ["generated_at", "changed_paths", "selected_arcs", "selected_tests", "stop_condition", "skipped_rings", "rationale"],
  "properties": {
    "generated_at": { "type": "string" },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "selected_arcs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "reason", "local_validate", "boundary_validate", "public_api"],
        "properties": {
          "name": { "type": "string" },
          "reason": { "type": "string" },
          "local_validate": { "type": "array", "items": { "type": "string" } },
          "boundary_validate": { "type": "array", "items": { "type": "string" } },
          "public_api": { "type": "boolean" }
        }
      }
    },
    "selected_tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["arc", "command", "ring", "selection_reason"],
        "properties": {
          "arc": { "type": "string" },
          "command": { "type": "string" },
          "ring": { "type": "string" },
          "selection_reason": { "type": "string" }
        }
      }
    },
    "stop_condition": { "type": "string" },
    "skipped_rings": { "type": "array", "items": { "type": "string" } },
    "rationale": { "type": "array", "items": { "type": "string" } }
  }
}
