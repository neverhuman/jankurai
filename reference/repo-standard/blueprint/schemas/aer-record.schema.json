{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-native-rust.dev/schemas/aer-record.schema.json",
  "title": "Agent Exception Record",
  "type": "object",
  "required": ["id", "class_id", "rule", "exception", "reason", "risk", "owner", "doc_links", "sunset_condition"],
  "properties": {
    "id": { "type": "string" },
    "class_id": { "type": "string" },
    "rule": { "type": "string" },
    "exception": { "type": "string" },
    "reason": { "type": "string" },
    "risk": { "type": "string" },
    "owner": { "type": "string" },
    "doc_links": { "type": "array", "items": { "type": "string" } },
    "sunset_condition": { "type": "string" }
  }
}
