{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-native-rust.dev/schemas/test-map.schema.json",
  "title": "Test Map",
  "type": "object",
  "required": ["generated_at", "workspace_root", "entries"],
  "properties": {
    "generated_at": { "type": "string" },
    "workspace_root": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "arc",
          "source_roots",
          "unit_tests",
          "doctests",
          "integration_harnesses",
          "reverse_dependency_tests",
          "smoke_tests",
          "e2e_gates",
          "selection_reason",
          "estimated_cost",
          "required_for_change_types"
        ],
        "properties": {
          "arc": { "type": "string" },
          "source_roots": { "type": "array", "items": { "type": "string" } },
          "unit_tests": { "type": "array", "items": { "type": "string" } },
          "doctests": { "type": "array", "items": { "type": "string" } },
          "integration_harnesses": { "type": "array", "items": { "type": "string" } },
          "reverse_dependency_tests": { "type": "array", "items": { "type": "string" } },
          "smoke_tests": { "type": "array", "items": { "type": "string" } },
          "e2e_gates": { "type": "array", "items": { "type": "string" } },
          "selection_reason": { "type": "string" },
          "estimated_cost": { "type": "string" },
          "required_for_change_types": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
