{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-native-rust.dev/schemas/agent-map.schema.json",
  "title": "Agent Map",
  "type": "object",
  "required": ["generated_at", "workspace_root", "validation_order", "shared_contracts", "ci_profiles", "instruction_roots", "members"],
  "properties": {
    "generated_at": { "type": "string" },
    "workspace_root": { "type": "string" },
    "validation_order": { "type": "array", "items": { "type": "string" } },
    "shared_contracts": { "type": "array", "items": { "type": "string" } },
    "ci_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "commands"],
        "properties": {
          "name": { "type": "string" },
          "commands": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "instruction_roots": { "type": "array", "items": { "type": "string" } },
    "members": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "manifest_path",
          "package_root",
          "direct_dependencies",
          "reverse_dependencies",
          "public_surfaces",
          "risk_tags",
          "instruction_locations",
          "validation_commands",
          "api_surface_hash",
          "proof_density",
          "context_roots",
          "exception_refs"
        ],
        "properties": {
          "name": { "type": "string" },
          "manifest_path": { "type": "string" },
          "package_root": { "type": "string" },
          "direct_dependencies": { "type": "array", "items": { "type": "string" } },
          "reverse_dependencies": { "type": "array", "items": { "type": "string" } },
          "public_surfaces": { "type": "array", "items": { "type": "string" } },
          "risk_tags": { "type": "array", "items": { "type": "string" } },
          "instruction_locations": { "type": "array", "items": { "type": "string" } },
          "validation_commands": {
            "type": "object",
            "required": ["local", "boundary"],
            "properties": {
              "local": { "type": "array", "items": { "type": "string" } },
              "boundary": { "type": "array", "items": { "type": "string" } }
            }
          },
          "api_surface_hash": { "type": "string" },
          "proof_density": { "type": "number" },
          "context_roots": { "type": "array", "items": { "type": "string" } },
          "exception_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
