{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-native-rust.dev/schemas/bench-report.schema.json",
  "title": "Agent Native Benchmark Report",
  "type": "object",
  "required": ["scenario", "generated_at", "results"],
  "properties": {
    "scenario": { "type": "string" },
    "generated_at": { "type": "string" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario", "variant", "wall_time_ms"],
        "properties": {
          "scenario": { "type": "string" },
          "variant": { "type": "string" },
          "wall_time_ms": { "type": "integer" },
          "peak_rss_kb": { "type": ["integer", "null"] },
          "thread_count_max": { "type": ["integer", "null"] },
          "throughput": { "type": ["number", "null"] },
          "latency_p50_ms": { "type": ["number", "null"] },
          "latency_p95_ms": { "type": ["number", "null"] },
          "context_files": { "type": ["integer", "null"] },
          "context_bytes": { "type": ["integer", "null"] },
          "selected_tests": { "type": ["integer", "null"] },
          "selected_arcs": { "type": ["integer", "null"] },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case_id", "category", "failure_mode", "expected_signal", "observed_signal", "success", "wall_time_ms", "docs"],
        "properties": {
          "case_id": { "type": "string" },
          "category": { "type": "string" },
          "failure_mode": { "type": "string" },
          "expected_signal": { "type": "string" },
          "observed_signal": { "type": "string" },
          "success": { "type": "boolean" },
          "wall_time_ms": { "type": "integer" },
          "docs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
