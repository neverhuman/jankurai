{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-native-rust.dev/schemas/exception-zoo-manifest.schema.json",
  "title": "Exception Zoo Manifest",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["case_id", "category", "failure_mode", "expected_signal", "docs", "fix_pattern", "benchmarkable", "mode", "manifest_path"],
    "properties": {
      "case_id": { "type": "string" },
      "category": { "type": "string" },
      "failure_mode": { "type": "string" },
      "expected_signal": { "type": "string" },
      "docs": { "type": "array", "items": { "type": "string" } },
      "fix_pattern": { "type": "string" },
      "benchmarkable": { "type": "boolean" },
      "mode": { "type": "string", "enum": ["compile", "test", "scan"] },
      "manifest_path": { "type": "string" },
      "cargo_args": { "type": "array", "items": { "type": "string" } }
    }
  }
}
