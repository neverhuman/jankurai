{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-native-rust.dev/schemas/aer-findings.schema.json",
  "title": "AER Findings Report",
  "type": "object",
  "required": ["generated_at", "workspace_root", "findings"],
  "properties": {
    "generated_at": { "type": "string" },
    "workspace_root": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["class_id", "severity", "confidence", "path", "summary", "suggested_fix"],
        "properties": {
          "class_id": { "type": "string" },
          "severity": { "type": "string", "enum": ["note", "warning", "error"] },
          "confidence": { "type": "number" },
          "path": { "type": "string" },
          "summary": { "type": "string" },
          "suggested_fix": { "type": "string" },
          "existing_exception": { "type": ["string", "null"] }
        }
      }
    }
  }
}
