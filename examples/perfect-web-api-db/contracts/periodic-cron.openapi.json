{
  "openapi": "3.1.0",
  "info": {
    "title": "Periodic Cron Schedules",
    "version": "1.0.0",
    "description": "API for managing deterministic periodic cron execution schedules."
  },
  "paths": {
    "/v1/cron-schedules": {
      "get": {
        "summary": "List cron schedules",
        "operationId": "listCronSchedules",
        "responses": {
          "200": {
            "description": "A list of cron schedules",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/CronSchedule" }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a cron schedule",
        "operationId": "createCronSchedule",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateCronSchedule" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "The created schedule",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CronSchedule" }
              }
            }
          }
        }
      }
    },
    "/v1/cron-schedules/{schedule_id}": {
      "get": {
        "summary": "Get a cron schedule",
        "operationId": "getCronSchedule",
        "parameters": [
          {
            "name": "schedule_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "The requested schedule",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CronSchedule" }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "Update a cron schedule",
        "operationId": "updateCronSchedule",
        "parameters": [
          {
            "name": "schedule_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateCronSchedule" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The updated schedule",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CronSchedule" }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "Delete a cron schedule",
        "operationId": "deleteCronSchedule",
        "parameters": [
          {
            "name": "schedule_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": { "description": "Successfully deleted" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CronSchedule": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "expression": { "type": "string", "description": "Standard cron expression" },
          "payload_ref": { "type": "string", "description": "Opaque reference to the payload to enqueue when triggered" },
          "is_paused": { "type": "boolean" },
          "last_run_at": { "type": "string", "format": "date-time", "nullable": true },
          "next_run_at": { "type": "string", "format": "date-time", "nullable": true }
        },
        "required": ["id", "expression", "payload_ref", "is_paused"]
      },
      "CreateCronSchedule": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "expression": { "type": "string" },
          "payload_ref": { "type": "string" }
        },
        "required": ["id", "expression", "payload_ref"]
      },
      "UpdateCronSchedule": {
        "type": "object",
        "properties": {
          "expression": { "type": "string" },
          "is_paused": { "type": "boolean" }
        }
      }
    }
  }
}
