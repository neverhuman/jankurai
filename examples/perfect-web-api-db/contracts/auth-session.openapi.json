{
  "openapi": "3.1.0",
  "info": {
    "title": "perfect-web-api-db auth-session cell",
    "version": "0.1.0",
    "description": "Provider-neutral auth/session shell. The contract exposes session lifecycle shape without making provider credentials durable truth."
  },
  "paths": {
    "/session": {
      "post": {
        "operationId": "createSession",
        "summary": "Create a session from provider-validated identity material",
        "tags": ["auth-session"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSessionRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Session created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Session"
                }
              }
            }
          },
          "401": {
            "description": "Credential rejected by provider boundary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "409": {
            "description": "Active session limit reached",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "revokeCurrentSession",
        "summary": "Revoke the caller's current session",
        "tags": ["auth-session"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "204": {
            "description": "Current session revoked"
          },
          "401": {
            "description": "No active session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      }
    },
    "/session/{sessionId}": {
      "delete": {
        "operationId": "revokeSession",
        "summary": "Revoke a session by ID; admin or owner action",
        "tags": ["auth-session"],
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "sessionId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": {
            "description": "Session revoked"
          },
          "403": {
            "description": "Caller lacks revoke permission",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "404": {
            "description": "Session not found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "CreateSessionRequest": {
        "type": "object",
        "required": ["email", "credential"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "credential": {
            "type": "string",
            "minLength": 12,
            "description": "Provider-bound credential material. Do not persist this field."
          },
          "provider": {
            "type": "string",
            "enum": ["local-shell", "oidc-shell", "saml-shell", "passkey-shell"],
            "default": "local-shell"
          }
        }
      },
      "Session": {
        "type": "object",
        "required": ["id", "accountId", "createdAt", "expiresAt", "revoked"],
        "properties": {
          "id": { "type": "string" },
          "accountId": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "expiresAt": { "type": "string", "format": "date-time" },
          "revoked": { "type": "boolean" }
        }
      },
      "ProblemDetail": {
        "type": "object",
        "description": "RFC 9457 Problem Details for auth/session API errors",
        "required": ["type", "title", "status"],
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" },
          "instance": { "type": "string", "format": "uri" }
        }
      }
    }
  }
}
