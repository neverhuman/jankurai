{
  "openapi": "3.0.3",
  "info": {
    "title": "Perfect Web API DB Background Job Cell",
    "version": "0.1.0",
    "description": "Certified-cell contract for dry-run/prove-only background job orchestration. Provider-backed queues remain adapter concerns."
  },
  "paths": {
    "/background-jobs": {
      "post": {
        "summary": "Enqueue a background job",
        "operationId": "enqueueBackgroundJob",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/EnqueueBackgroundJobRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Job enqueued",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BackgroundJob" }
              }
            }
          },
          "403": { "description": "Actor lacks write authority" },
          "409": { "description": "Job id already exists" }
        }
      }
    },
    "/background-jobs/next": {
      "get": {
        "summary": "Claim the next due job from a queue",
        "operationId": "claimNextBackgroundJob",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "queue",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "minLength": 1 }
          },
          {
            "name": "worker_id",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "minLength": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "A job was claimed or no job is currently due",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["job"],
                  "properties": {
                    "job": {
                      "oneOf": [
                        { "$ref": "#/components/schemas/BackgroundJob" },
                        { "type": "null" }
                      ]
                    }
                  },
                  "additionalProperties": false
                }
              }
            }
          },
          "403": { "description": "Actor lacks worker/admin authority" }
        }
      }
    },
    "/background-jobs/{job_id}/complete": {
      "post": {
        "summary": "Mark a running job complete",
        "operationId": "completeBackgroundJob",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "minLength": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Job completed",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BackgroundJob" }
              }
            }
          },
          "403": { "description": "Actor lacks worker/admin authority" },
          "409": { "description": "Job is not running" }
        }
      }
    },
    "/background-jobs/{job_id}/fail": {
      "post": {
        "summary": "Record a job failure and either retry or exhaust it",
        "operationId": "failBackgroundJob",
        "security": [{ "bearerAuth": [] }],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "minLength": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/FailBackgroundJobRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Job failure recorded",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/BackgroundJob" }
              }
            }
          },
          "403": { "description": "Actor lacks worker/admin authority" },
          "409": { "description": "Job is not running" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Auth/session cell credential resolved to an application-layer account before commands run."
      }
    },
    "schemas": {
      "BackgroundJobStatus": {
        "type": "string",
        "enum": ["queued", "running", "completed", "failed", "cancelled"]
      },
      "BackgroundJobKind": {
        "type": "string",
        "enum": ["email-delivery", "webhook-dispatch", "report-export", "custom"]
      },
      "EnqueueBackgroundJobRequest": {
        "type": "object",
        "required": ["job_id", "queue", "kind", "payload_ref", "run_at_epoch_seconds"],
        "properties": {
          "job_id": { "type": "string", "minLength": 1 },
          "queue": { "type": "string", "minLength": 1 },
          "kind": { "$ref": "#/components/schemas/BackgroundJobKind" },
          "payload_ref": {
            "type": "string",
            "minLength": 1,
            "description": "Opaque reference to payload material; raw payloads are not stored in the job record."
          },
          "organization_id": { "type": ["string", "null"] },
          "run_at_epoch_seconds": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      },
      "FailBackgroundJobRequest": {
        "type": "object",
        "required": ["error"],
        "properties": {
          "error": { "type": "string", "minLength": 1 }
        },
        "additionalProperties": false
      },
      "BackgroundJob": {
        "type": "object",
        "required": [
          "job_id",
          "queue",
          "kind",
          "payload_ref",
          "created_by",
          "status",
          "attempts",
          "max_attempts",
          "run_at_epoch_seconds"
        ],
        "properties": {
          "job_id": { "type": "string" },
          "queue": { "type": "string" },
          "kind": { "$ref": "#/components/schemas/BackgroundJobKind" },
          "payload_ref": { "type": "string" },
          "created_by": { "type": "string" },
          "organization_id": { "type": ["string", "null"] },
          "status": { "$ref": "#/components/schemas/BackgroundJobStatus" },
          "attempts": { "type": "integer", "minimum": 0 },
          "max_attempts": { "type": "integer", "minimum": 1 },
          "run_at_epoch_seconds": { "type": "integer", "minimum": 0 },
          "locked_by": { "type": ["string", "null"] },
          "completed_at_epoch_seconds": { "type": ["integer", "null"], "minimum": 0 },
          "last_error": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    }
  }
}
