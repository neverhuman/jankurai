{
  "openapi": "3.1.0",
  "info": {
    "title": "Organization Team Cell API",
    "version": "0.1.0",
    "description": "Certified organization/team shell contract for the Jankurai reference platform. Provider directory sync and billing seats are intentionally out of scope."
  },
  "paths": {
    "/v1/organizations/{organizationId}/teams": {
      "get": {
        "summary": "List teams in an organization",
        "operationId": "listOrganizationTeams",
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Teams visible to the authenticated account",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "required": ["teams"],
                  "properties": {
                    "teams": {
                      "type": "array",
                      "items": { "$ref": "#/$defs/OrganizationTeam" }
                    }
                  }
                }
              }
            }
          },
          "401": { "$ref": "#/$defs/responses/Unauthorized" },
          "403": { "$ref": "#/$defs/responses/Forbidden" }
        }
      },
      "post": {
        "summary": "Create a team",
        "operationId": "createOrganizationTeam",
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/$defs/CreateOrganizationTeamRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created team",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/$defs/OrganizationTeam" }
              }
            }
          },
          "400": { "$ref": "#/$defs/responses/BadRequest" },
          "401": { "$ref": "#/$defs/responses/Unauthorized" },
          "403": { "$ref": "#/$defs/responses/Forbidden" }
        }
      }
    },
    "/v1/teams/{teamId}/members": {
      "post": {
        "summary": "Add a team member",
        "operationId": "addOrganizationTeamMember",
        "parameters": [
          {
            "name": "teamId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/$defs/AddTeamMemberRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created membership",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/$defs/TeamMembership" }
              }
            }
          },
          "400": { "$ref": "#/$defs/responses/BadRequest" },
          "401": { "$ref": "#/$defs/responses/Unauthorized" },
          "403": { "$ref": "#/$defs/responses/Forbidden" },
          "404": { "$ref": "#/$defs/responses/NotFound" }
        }
      }
    }
  },
  "$defs": {
    "OrganizationTeam": {
      "type": "object",
      "required": ["id", "organizationId", "name", "archived"],
      "properties": {
        "id": { "type": "string" },
        "organizationId": { "type": "string" },
        "name": { "type": "string", "minLength": 1 },
        "archived": { "type": "boolean" }
      }
    },
    "TeamMembership": {
      "type": "object",
      "required": ["teamId", "accountId", "role"],
      "properties": {
        "teamId": { "type": "string" },
        "accountId": { "type": "string" },
        "role": { "$ref": "#/$defs/TeamRole" }
      }
    },
    "TeamRole": {
      "type": "string",
      "enum": ["manager", "contributor", "viewer"]
    },
    "CreateOrganizationTeamRequest": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "AddTeamMemberRequest": {
      "type": "object",
      "required": ["accountId", "role"],
      "properties": {
        "accountId": { "type": "string" },
        "role": { "$ref": "#/$defs/TeamRole" }
      },
      "additionalProperties": false
    },
    "ProblemDetail": {
      "type": "object",
      "required": ["type", "title", "status"],
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "status": { "type": "integer" },
        "detail": { "type": "string" },
        "instance": { "type": "string" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Invalid organization/team request",
        "content": { "application/problem+json": { "schema": { "$ref": "#/$defs/ProblemDetail" } } }
      },
      "Unauthorized": {
        "description": "Authentication required",
        "content": { "application/problem+json": { "schema": { "$ref": "#/$defs/ProblemDetail" } } }
      },
      "Forbidden": {
        "description": "Membership management permission required",
        "content": { "application/problem+json": { "schema": { "$ref": "#/$defs/ProblemDetail" } } }
      },
      "NotFound": {
        "description": "Organization or team not found",
        "content": { "application/problem+json": { "schema": { "$ref": "#/$defs/ProblemDetail" } } }
      }
    }
  }
}
