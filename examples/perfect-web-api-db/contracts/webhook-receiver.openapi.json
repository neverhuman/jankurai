{
  "openapi": "3.1.0",
  "info": {
    "title": "Webhook Receiver API",
    "version": "0.1.0"
  },
  "paths": {
    "/webhooks/{provider}": {
      "post": {
        "operationId": "receiveWebhook",
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Webhook received and accepted for processing"
          },
          "400": {
            "description": "Invalid signature or malformed payload"
          }
        }
      }
    }
  }
}
