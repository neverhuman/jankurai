{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/coverage-sources.schema.json",
  "title": "jankurai coverage sources",
  "type": "object",
  "required": ["version", "source"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "source": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "source": {
      "type": "object",
      "required": ["id", "kind", "format", "mode", "artifacts"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "type": "string",
          "enum": [
            "line_coverage",
            "mutation",
            "property_fuzz",
            "api_contract",
            "ui_e2e",
            "db_migration",
            "container",
            "supply_chain",
            "dead_code",
            "type_coverage",
            "jankurai_artifact"
          ]
        },
        "format": {
          "type": "string",
          "enum": [
            "lcov",
            "cargo-mutants-json",
            "stryker-json",
            "trivy-json",
            "hadolint-json",
            "jankurai-json",
            "generic-json-summary"
          ]
        },
        "mode": {
          "type": "string",
          "enum": ["required", "advisory", "disabled", "auto"]
        },
        "owner": { "type": "string" },
        "lane": { "type": "string" },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "applies_to": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "rules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "hard_changed_line_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "soft_total_line_coverage": { "type": "number", "minimum": 0, "maximum": 1 },
        "hard_survivors_on_changed_paths": { "type": "integer", "minimum": 0 },
        "hard_critical_vulnerabilities": { "type": "integer", "minimum": 0 },
        "hard_high_vulnerabilities": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
