{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/security-policy.schema.json",
  "title": "jankurai security policy",
  "type": "object",
  "required": [
    "schema_version",
    "enabled_tools",
    "required_tools",
    "advisory_tools"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "enabled_tools": { "type": "array", "items": { "type": "string" } },
    "required_tools": { "type": "array", "items": { "type": "string" } },
    "advisory_tools": { "type": "array", "items": { "type": "string" } },
    "severity_thresholds": {
      "type": "object",
      "properties": {
        "fail_lane_on": { "type": "string" }
      }
    }
  },
  "additionalProperties": true
}
