{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/finding.schema.json",
  "title": "jankurai finding",
  "type": "object",
  "required": [
    "severity",
    "category",
    "path",
    "problem",
    "agent_fix",
    "evidence",
    "check_id",
    "hardness",
    "confidence",
    "evidence_kind",
    "rerun_command",
    "fingerprint"
  ],
  "properties": {
    "severity": { "enum": ["critical", "high", "medium", "low"] },
    "category": { "type": "string" },
    "path": { "type": "string" },
    "problem": { "type": "string" },
    "agent_fix": { "type": "string" },
    "evidence": { "type": "array", "items": { "type": "string" } },
    "check_id": { "type": "string" },
    "hardness": { "enum": ["hard", "soft"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "evidence_kind": { "type": "string" },
    "rerun_command": { "type": "string" },
    "fingerprint": { "type": "string" },
    "rule_id": { "type": "string" },
    "owner": { "type": "string" },
    "lane": { "type": "string" }
  }
}
