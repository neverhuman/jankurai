{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/proofmark-receipt.schema.json",
  "title": "jankurai proofmark receipt",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "generated_at",
    "repo_root",
    "git_head",
    "mode",
    "changed_paths",
    "changed_units",
    "coverage",
    "mutation",
    "obligation_results",
    "satisfied_obligations",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "git_head": { "type": "string" },
    "mode": { "type": "string", "enum": ["advisory", "required"] },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "changed_units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "unit",
          "changed_lines",
          "covered_changed_lines",
          "uncovered_changed_lines",
          "coverage_status"
        ],
        "properties": {
          "path": { "type": "string" },
          "unit": { "type": "string" },
          "changed_lines": { "type": "array", "items": { "type": "integer" } },
          "covered_changed_lines": { "type": "array", "items": { "type": "integer" } },
          "uncovered_changed_lines": { "type": "array", "items": { "type": "integer" } },
          "coverage_status": {
            "type": "string",
            "enum": ["pass", "review", "unavailable"]
          }
        },
        "additionalProperties": false
      }
    },
    "coverage": {
      "type": "object",
      "required": [
        "source",
        "changed_line_count",
        "covered_changed_line_count",
        "uncovered_changed_line_count",
        "status"
      ],
      "properties": {
        "source": { "type": "string" },
        "changed_line_count": { "type": "integer", "minimum": 0 },
        "covered_changed_line_count": { "type": "integer", "minimum": 0 },
        "uncovered_changed_line_count": { "type": "integer", "minimum": 0 },
        "status": { "type": "string", "enum": ["pass", "review", "unavailable"] }
      },
      "additionalProperties": false
    },
    "mutation": {
      "type": "object",
      "required": ["source", "status", "killed", "survived", "timeout"],
      "properties": {
        "source": { "type": "string" },
        "status": { "type": "string", "enum": ["pass", "review", "unavailable"] },
        "killed": { "type": "integer", "minimum": 0 },
        "survived": { "type": "integer", "minimum": 0 },
        "timeout": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "obligation_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "obligation_id",
          "path",
          "rule_ids",
          "required_lanes",
          "status",
          "coverage_status",
          "mutation_status",
          "negative_proof_status",
          "evidence",
          "residual_risk"
        ],
        "properties": {
          "obligation_id": { "type": "string" },
          "path": { "type": "string" },
          "rule_ids": { "type": "array", "items": { "type": "string" } },
          "required_lanes": { "type": "array", "items": { "type": "string" } },
          "status": { "type": "string", "enum": ["pass", "review"] },
          "coverage_status": { "type": "string", "enum": ["pass", "review", "unavailable"] },
          "mutation_status": { "type": "string", "enum": ["pass", "review", "unavailable"] },
          "negative_proof_status": {
            "type": "string",
            "enum": ["present", "missing", "not_required"]
          },
          "evidence": { "type": "array", "items": { "type": "string" } },
          "residual_risk": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "satisfied_obligations": { "type": "array", "items": { "type": "string" } },
    "summary": {
      "type": "object",
      "required": [
        "total_obligations",
        "satisfied_obligations",
        "review_obligations",
        "changed_units",
        "verdict"
      ],
      "properties": {
        "total_obligations": { "type": "integer", "minimum": 0 },
        "satisfied_obligations": { "type": "integer", "minimum": 0 },
        "review_obligations": { "type": "integer", "minimum": 0 },
        "changed_units": { "type": "integer", "minimum": 0 },
        "verdict": { "type": "string", "enum": ["pass", "review", "block"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
