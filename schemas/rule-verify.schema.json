{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/rule-verify.schema.json",
  "title": "jankurai rule verification",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "status",
    "known_rule_count",
    "scanned_files",
    "references",
    "unknown_references",
    "missing_from_standard"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "const": "jankurai rules verify" },
    "status": { "type": "string", "enum": ["pass", "fail"] },
    "known_rule_count": { "type": "integer", "minimum": 0 },
    "scanned_files": { "type": "integer", "minimum": 0 },
    "references": { "type": "array", "items": { "type": "object" } },
    "unknown_references": { "type": "array", "items": { "type": "object" } },
    "missing_from_standard": { "type": "array", "items": { "type": "string" } }
  }
}
