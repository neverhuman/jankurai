{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/ux-qa.schema.json",
  "title": "jankurai UX QA report",
  "type": "object",
  "required": ["reports"],
  "properties": {
    "reports": {
      "type": "array",
      "items": { "$ref": "#/$defs/uxQaReport" }
    }
  },
  "$defs": {
    "uxQaRuleId": {
      "type": "string",
      "enum": [
        "edge-clearance",
        "target-size",
        "interactive-overlap",
        "text-clipping",
        "button-wrap",
        "horizontal-overflow",
        "sticky-obstruction",
        "z-index-token",
        "focus-visible",
        "form-label",
        "nested-scrollbar"
      ]
    },
    "uxQaSeverity": {
      "type": "string",
      "enum": ["error", "warning"]
    },
    "uxQaDecision": {
      "type": "string",
      "enum": ["pass", "warn", "review", "block"]
    },
    "uxQaBaselineMode": {
      "type": "string",
      "enum": ["pass", "review", "block"]
    },
    "uxQaState": {
      "type": "string",
      "enum": ["loading", "empty", "error", "success", "permission-denied"]
    },
    "uxQaViewport": {
      "type": "object",
      "required": ["width", "height"],
      "properties": {
        "width": { "type": "number" },
        "height": { "type": "number" }
      }
    },
    "uxQaBox": {
      "type": "object",
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "number" },
        "y": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" }
      }
    },
    "uxQaPageMetrics": {
      "type": "object",
      "required": ["scrollWidth", "clientWidth", "scrollHeight", "clientHeight"],
      "properties": {
        "scrollWidth": { "type": "number" },
        "clientWidth": { "type": "number" },
        "scrollHeight": { "type": "number" },
        "clientHeight": { "type": "number" }
      }
    },
    "uxQaElement": {
      "type": "object",
      "required": [
        "selector",
        "tag",
        "role",
        "interactive",
        "name",
        "text",
        "box",
        "lineCount",
        "scrollWidth",
        "scrollHeight",
        "clientWidth",
        "clientHeight",
        "overflowX",
        "overflowY",
        "position",
        "zIndex",
        "pointerEvents",
        "disabled",
        "inert",
        "focusVisible",
        "labelled",
        "hitTargetSelector",
        "obstructedBy",
        "selectorResolved"
      ],
      "properties": {
        "selector": { "type": "string" },
        "tag": { "type": "string" },
        "role": {
          "type": ["string", "null"]
        },
        "interactive": { "type": "boolean" },
        "name": { "type": "string" },
        "text": { "type": "string" },
        "box": { "$ref": "#/$defs/uxQaBox" },
        "lineCount": { "type": "integer", "minimum": 0 },
        "scrollWidth": { "type": "number" },
        "scrollHeight": { "type": "number" },
        "clientWidth": { "type": "number" },
        "clientHeight": { "type": "number" },
        "overflowX": { "type": "string" },
        "overflowY": { "type": "string" },
        "position": { "type": "string" },
        "zIndex": { "type": "string" },
        "pointerEvents": { "type": "string" },
        "disabled": { "type": "boolean" },
        "inert": { "type": "boolean" },
        "focusVisible": { "type": "boolean" },
        "labelled": { "type": "boolean" },
        "hitTargetSelector": {
          "type": ["string", "null"]
        },
        "obstructedBy": {
          "type": ["string", "null"]
        },
        "selectorResolved": { "type": "boolean" }
      }
    },
    "uxQaViolation": {
      "type": "object",
      "required": ["ruleId", "severity", "message", "selector", "evidence"],
      "properties": {
        "ruleId": { "$ref": "#/$defs/uxQaRuleId" },
        "severity": { "$ref": "#/$defs/uxQaSeverity" },
        "message": { "type": "string" },
        "selector": { "type": "string" },
        "evidence": { "type": "string" },
        "box": { "$ref": "#/$defs/uxQaBox" },
        "artifactPath": { "type": "string" }
      }
    },
    "uxQaArtifactKind": {
      "type": "string",
      "enum": [
        "screenshot",
        "crop",
        "aria-snapshot",
        "accessibility",
        "visual-baseline",
        "visual-diff"
      ]
    },
    "uxQaArtifact": {
      "type": "object",
      "required": ["kind", "path", "viewport"],
      "properties": {
        "kind": { "$ref": "#/$defs/uxQaArtifactKind" },
        "path": { "type": "string" },
        "sha256": { "type": "string" },
        "viewport": { "$ref": "#/$defs/uxQaViewport" },
        "selector": { "type": "string" },
        "ruleId": { "$ref": "#/$defs/uxQaRuleId" }
      }
    },
    "uxQaVisualBaselineStatus": {
      "type": "string",
      "enum": ["not-configured", "missing-baseline", "matched", "changed"]
    },
    "uxQaVisualBaselineSummary": {
      "type": "object",
      "required": ["mode", "status", "decision"],
      "properties": {
        "mode": { "$ref": "#/$defs/uxQaBaselineMode" },
        "status": { "$ref": "#/$defs/uxQaVisualBaselineStatus" },
        "decision": { "$ref": "#/$defs/uxQaDecision" },
        "actualPath": { "type": "string" },
        "baselinePath": { "type": "string" },
        "diffPath": { "type": "string" },
        "actualSha256": { "type": "string" },
        "baselineSha256": { "type": "string" },
        "owner": { "type": "string" },
        "approvedBy": { "type": "string" },
        "approvedAt": { "type": "string" },
        "approvalNote": { "type": "string" }
      }
    },
    "uxQaArtifactCoverage": {
      "type": "object",
      "required": ["required", "present", "missing"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaArtifactKind" }
        },
        "present": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaArtifactKind" }
        },
        "missing": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaArtifactKind" }
        }
      }
    },
    "uxQaAccessibilitySummary": {
      "type": "object",
      "required": ["violations", "incomplete", "passes"],
      "properties": {
        "violations": { "type": "integer", "minimum": 0 },
        "incomplete": { "type": "integer", "minimum": 0 },
        "passes": { "type": "integer", "minimum": 0 },
        "artifactPath": { "type": "string" }
      }
    },
    "uxQaSummary": {
      "type": "object",
      "required": ["errors", "warnings", "byRule"],
      "properties": {
        "errors": { "type": "integer", "minimum": 0 },
        "warnings": { "type": "integer", "minimum": 0 },
        "byRule": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "uxQaStateCoverage": {
      "type": "object",
      "required": ["required", "declared", "missing"],
      "properties": {
        "required": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaState" }
        },
        "declared": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaState" }
        },
        "missing": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaState" }
        }
      }
    },
    "uxQaReport": {
      "type": "object",
      "required": [
        "schemaVersion",
        "toolVersion",
        "url",
        "checkedAt",
        "viewport",
        "metrics",
        "elements",
        "violations",
        "artifacts",
        "summary",
        "decision"
      ],
      "properties": {
        "schemaVersion": {
          "type": "string",
          "enum": ["1.2.0", "1.3.0", "1.4.0"]
        },
        "toolVersion": { "type": "string" },
        "url": { "type": "string" },
        "routeId": { "type": "string" },
        "storyId": { "type": "string" },
        "state": { "$ref": "#/$defs/uxQaState" },
        "browserName": { "type": "string" },
        "checkedAt": { "type": "string" },
        "viewport": { "$ref": "#/$defs/uxQaViewport" },
        "metrics": { "$ref": "#/$defs/uxQaPageMetrics" },
        "elements": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaElement" }
        },
        "violations": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaViolation" }
        },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/uxQaArtifact" }
        },
        "artifactCoverage": { "$ref": "#/$defs/uxQaArtifactCoverage" },
        "accessibility": { "$ref": "#/$defs/uxQaAccessibilitySummary" },
        "summary": { "$ref": "#/$defs/uxQaSummary" },
        "stateCoverage": { "$ref": "#/$defs/uxQaStateCoverage" },
        "visualBaseline": { "$ref": "#/$defs/uxQaVisualBaselineSummary" },
        "decision": { "$ref": "#/$defs/uxQaDecision" }
      }
    }
  }
}
