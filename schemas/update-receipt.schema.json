{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/update-receipt.schema.json",
  "title": "jankurai update receipt",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "created_at",
    "repo_root",
    "current_version",
    "update_channel",
    "source",
    "self_update_requested",
    "self_update_applied",
    "repo_update_applied"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "created_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "current_version": { "type": "string" },
    "latest_version": { "type": "string" },
    "update_channel": { "type": "string" },
    "source": { "type": "string" },
    "resolved_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_source", "resolved_source", "reason"],
      "properties": {
        "requested_source": { "type": "string" },
        "resolved_source": { "type": "string" },
        "source_url": { "type": "string" },
        "latest_version": { "type": "string" },
        "install_command": { "type": "array", "items": { "type": "string" } },
        "install_root": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "self_update_requested": { "type": "boolean" },
    "self_update_applied": { "type": "boolean" },
    "repo_update_applied": { "type": "boolean" },
    "reexec_command": { "type": "string" },
    "post_upgrade_score_command": { "type": "string" },
    "post_upgrade_score_mode": { "type": "string" },
    "post_upgrade_score_json": { "type": "string" },
    "post_upgrade_score_md": { "type": "string" },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action", "reason"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string" },
          "reason": { "type": "string" },
          "current_hash": { "type": "string" },
          "installed_hash": { "type": "string" },
          "desired_hash": { "type": "string" },
          "merge_policy": { "type": "string" }
        }
      }
    },
    "commands_run": { "type": "array", "items": { "type": "string" } },
    "next_command": { "type": "string" },
    "residual_risk": { "type": "array", "items": { "type": "string" } },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  }
}
