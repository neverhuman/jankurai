{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/security-evidence.schema.json",
  "title": "jankurai security evidence envelope",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "generated_at",
    "repo_root",
    "lane",
    "wrapper",
    "exit_code",
    "elapsed_ms",
    "log_path",
    "policy",
    "commands"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "git_head": { "type": "string" },
    "lane": { "const": "security" },
    "wrapper": {
      "type": "object",
      "required": ["kind", "path", "strict"],
      "properties": {
        "kind": { "const": "bash_script" },
        "path": { "type": "string" },
        "strict": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "exit_code": { "type": "integer" },
    "elapsed_ms": { "type": "integer", "minimum": 0 },
    "log_path": { "type": "string" },
    "policy": {
      "type": "object",
      "required": [
        "schema_version",
        "profile",
        "enabled_tools",
        "required_tools",
        "advisory_tools",
        "require_one_of",
        "fail_lane_on"
      ],
      "properties": {
        "schema_version": { "type": "string" },
        "profile": { "enum": ["local", "ci", "release"] },
        "enabled_tools": { "type": "array", "items": { "type": "string" } },
        "required_tools": { "type": "array", "items": { "type": "string" } },
        "advisory_tools": { "type": "array", "items": { "type": "string" } },
        "require_one_of": {
          "type": "array",
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "fail_lane_on": {
          "enum": ["low", "medium", "high", "critical"]
        }
      },
      "additionalProperties": false
    },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "label",
          "shell_command",
          "status",
          "advisory",
          "required_by_policy",
          "blocking"
        ],
        "properties": {
          "label": { "type": "string" },
          "shell_command": { "type": "string" },
          "tool": { "type": "string" },
          "status": { "enum": ["ran", "skipped", "failed"] },
          "exit_code": { "type": "integer" },
          "advisory": { "type": "boolean" },
          "required_by_policy": { "type": "boolean" },
          "blocking": { "type": "boolean" },
          "stderr_excerpt": { "type": "string", "maxLength": 500 },
          "finding_count": { "type": "integer", "minimum": 0 },
          "highest_severity": { "enum": ["critical", "high", "medium", "low", "ok", "none"] },
          "normalized_decision": { "enum": ["pass", "block", "review"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
