{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/adoption-plan.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "status",
    "generated_at",
    "source_root",
    "mode",
    "requested_profile",
    "recommended_profile",
    "risk_tier",
    "detected_surfaces",
    "source_stack",
    "target_stack",
    "liability_score",
    "audit_score",
    "safe_commands",
    "tool_rollout",
    "stop_conditions",
    "next_milestones",
    "artifacts",
    "warnings"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "status": { "type": "string" },
    "generated_at": { "type": "string" },
    "source_root": { "type": "string" },
    "mode": { "type": "string", "enum": ["observe", "advisory", "ratchet"] },
    "requested_profile": { "type": "string" },
    "recommended_profile": { "type": "string" },
    "risk_tier": { "type": "string", "enum": ["low", "medium", "high"] },
    "detected_surfaces": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_stack": { "type": "string" },
    "target_stack": { "type": "string" },
    "liability_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "audit_score": { "type": ["integer", "null"], "minimum": 0, "maximum": 100 },
    "safe_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tool_rollout": {
      "type": "array",
      "items": { "$ref": "#/$defs/toolRolloutItem" }
    },
    "stop_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_milestones": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "toolRolloutItem": {
      "type": "object",
      "required": [
        "id",
        "category",
        "status",
        "score_priority",
        "next_command",
        "artifact_paths"
      ],
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string" },
        "score_priority": { "type": "integer", "minimum": 0 },
        "next_command": { "type": "string" },
        "artifact_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  }
}
