{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/boundaries.schema.json",
  "title": "jankurai boundary manifest",
  "type": "object",
  "required": ["stack", "queues"],
  "properties": {
    "stack": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "queues": {
      "type": "object",
      "required": ["adapter_paths", "event_contract_paths", "generated_type_paths"],
      "properties": {
        "adapter_paths": { "type": "array", "items": { "type": "string" } },
        "event_contract_paths": { "type": "array", "items": { "type": "string" } },
        "generated_type_paths": { "type": "array", "items": { "type": "string" } },
        "client_markers": { "type": "array", "items": { "type": "string" } }
      }
    },
    "streaming_exception": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["runtime", "owner", "expires", "migration_path"],
        "properties": {
          "runtime": { "type": "string" },
          "classification": { "type": "string" },
          "reason": { "type": "string" },
          "owner": { "type": "string" },
          "expires": { "type": "string" },
          "migration_path": { "type": "string" }
        }
      }
    },
    "audited_runtime_boundary": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "paths",
          "classification",
          "product_surface",
          "runtime_language",
          "target_stack_exception",
          "reclassifies",
          "required_evidence",
          "required_checks"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "classification": { "type": "string", "minLength": 1 },
          "product_surface": { "type": "boolean" },
          "runtime_language": { "type": "string", "enum": ["python"] },
          "target_stack_exception": { "type": "boolean" },
          "reclassifies": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": [
                "non-optimal-product-language-found",
                "too-much-python-in-product-surface",
                "python-direct-product-truth-or-db-ownership"
              ]
            }
          },
          "proof_command": { "type": "string" },
          "rerun_command": { "type": "string" },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "required_checks": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
