{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/proofbind-witness.schema.json",
  "title": "jankurai proofbind surface witness",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "generated_at",
    "repo_root",
    "git_head",
    "mode",
    "changed_paths",
    "surfaces",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "git_head": { "type": "string" },
    "mode": { "type": "string", "enum": ["advisory", "required"] },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "surfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "surface_id",
          "path",
          "symbol",
          "surface_type",
          "severity",
          "risk_tags",
          "owner",
          "owner_route",
          "test_route",
          "proof_lane",
          "required_rules",
          "required_lanes",
          "repair_tasks"
        ],
        "properties": {
          "surface_id": { "type": "string" },
          "path": { "type": "string" },
          "symbol": { "type": "string" },
          "surface_type": {
            "type": "string",
            "enum": [
              "rust_public_api",
              "authz_boundary",
              "input_boundary",
              "sql_query",
              "db_migration",
              "cli_command",
              "mcp_tool",
              "unsafe_or_process_sink",
              "business_invariant"
            ]
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "risk_tags": { "type": "array", "items": { "type": "string" } },
          "owner": { "type": "string" },
          "owner_route": { "type": "string" },
          "test_route": { "type": "string" },
          "proof_lane": { "type": "string" },
          "required_rules": { "type": "array", "items": { "type": "string" } },
          "required_lanes": { "type": "array", "items": { "type": "string" } },
          "repair_tasks": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "changed_surface_count",
        "high_or_critical_surface_count",
        "by_surface_type",
        "by_owner",
        "verdict"
      ],
      "properties": {
        "changed_surface_count": { "type": "integer", "minimum": 0 },
        "high_or_critical_surface_count": { "type": "integer", "minimum": 0 },
        "by_surface_type": { "type": "object", "additionalProperties": { "type": "integer" } },
        "by_owner": { "type": "object", "additionalProperties": { "type": "integer" } },
        "verdict": { "type": "string", "enum": ["pass", "review", "block"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
