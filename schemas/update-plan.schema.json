{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/update-plan.schema.json",
  "title": "jankurai update plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "status",
    "generated_at",
    "repo_root",
    "current_version",
    "standard_version",
    "auditor_version",
    "schema_contract_version",
    "paper_edition",
    "target_stack_id",
    "update_channel",
    "source",
    "offline",
    "client_start",
    "self_update_requested",
    "self_update_available",
    "install_state",
    "install_manifest_path",
    "state_path",
    "plan_path",
    "md_path"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "status": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "current_version": { "type": "string" },
    "latest_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "schema_contract_version": { "type": "string" },
    "paper_edition": { "type": "string" },
    "target_stack_id": { "type": "string" },
    "update_channel": { "type": "string" },
    "source": { "type": "string" },
    "resolved_source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requested_source", "resolved_source", "reason"],
      "properties": {
        "requested_source": { "type": "string" },
        "resolved_source": { "type": "string" },
        "source_url": { "type": "string" },
        "latest_version": { "type": "string" },
        "install_command": { "type": "array", "items": { "type": "string" } },
        "install_root": { "type": "string" },
        "reason": { "type": "string" }
      }
    },
    "offline": { "type": "boolean" },
    "client_start": { "type": "boolean" },
    "self_update_requested": { "type": "boolean" },
    "self_update_available": { "type": "boolean" },
    "install_state": { "type": "string" },
    "install_manifest_path": { "type": "string" },
    "state_path": { "type": "string" },
    "plan_path": { "type": "string" },
    "md_path": { "type": "string" },
    "reexec_command": { "type": "string" },
    "post_upgrade_score_command": { "type": "string" },
    "post_upgrade_score_mode": { "type": "string" },
    "post_upgrade_score_json": { "type": "string" },
    "post_upgrade_score_md": { "type": "string" },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "action", "reason"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string" },
          "reason": { "type": "string" },
          "current_hash": { "type": "string" },
          "installed_hash": { "type": "string" },
          "desired_hash": { "type": "string" },
          "merge_policy": { "type": "string" }
        }
      }
    },
    "artifacts": { "type": "array", "items": { "type": "string" } }
  }
}
