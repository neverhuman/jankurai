{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/conformance-results.schema.json",
  "title": "jankurai conformance results",
  "type": "object",
  "required": [
    "schema_url",
    "schema_version",
    "standard_version",
    "auditor_version",
    "command",
    "generated_at",
    "fixture_root",
    "expected_root",
    "fixture_count",
    "pass_count",
    "fail_count",
    "results"
  ],
  "properties": {
    "schema_url": { "const": "schemas/conformance-results.schema.json" },
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "command": { "const": "jankurai conformance run" },
    "generated_at": { "type": "string" },
    "fixture_root": { "type": "string" },
    "expected_root": { "type": "string" },
    "fixture_count": { "type": "integer", "minimum": 0 },
    "pass_count": { "type": "integer", "minimum": 0 },
    "fail_count": { "type": "integer", "minimum": 0 },
    "results": {
      "type": "array",
      "items": { "$ref": "#/$defs/fixtureResult" }
    }
  },
  "$defs": {
    "decision": {
      "type": "string",
      "enum": ["pass", "block"]
    },
    "stringList": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ruleMatch": {
      "type": "object",
      "required": ["rule_id", "expected", "observed"],
      "properties": {
        "rule_id": { "type": "string" },
        "expected": { "type": "boolean" },
        "observed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "fixtureResult": {
      "type": "object",
      "required": [
        "fixture_id",
        "expected_audit_decision",
        "observed_audit_decision",
        "expected_witness_decision",
        "observed_witness_decision",
        "expected_rules",
        "observed_rules",
        "rule_matches",
        "missing_expected_rules",
        "expected_missing_evidence",
        "missing_evidence",
        "missing_expected_evidence",
        "result",
        "elapsed_ms",
        "artifact_paths"
      ],
      "properties": {
        "fixture_id": { "type": "string" },
        "expected_audit_decision": { "$ref": "#/$defs/decision" },
        "observed_audit_decision": { "$ref": "#/$defs/decision" },
        "expected_witness_decision": { "$ref": "#/$defs/decision" },
        "observed_witness_decision": { "$ref": "#/$defs/decision" },
        "expected_rules": { "$ref": "#/$defs/stringList" },
        "observed_rules": { "$ref": "#/$defs/stringList" },
        "rule_matches": {
          "type": "array",
          "items": { "$ref": "#/$defs/ruleMatch" }
        },
        "missing_expected_rules": { "$ref": "#/$defs/stringList" },
        "expected_missing_evidence": { "$ref": "#/$defs/stringList" },
        "missing_evidence": { "$ref": "#/$defs/stringList" },
        "missing_expected_evidence": { "$ref": "#/$defs/stringList" },
        "result": {
          "type": "string",
          "enum": ["pass", "fail"]
        },
        "elapsed_ms": { "type": "integer", "minimum": 0 },
        "artifact_paths": { "$ref": "#/$defs/stringList" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
