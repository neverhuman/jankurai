{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/proofbind-obligations.schema.json",
  "title": "jankurai proofbind obligations",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "generated_at",
    "repo_root",
    "git_head",
    "mode",
    "obligations",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "git_head": { "type": "string" },
    "mode": { "type": "string", "enum": ["advisory", "required"] },
    "obligations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "obligation_id",
          "surface_id",
          "path",
          "symbol",
          "surface_type",
          "severity",
          "risk_tags",
          "rule_ids",
          "required_lanes",
          "required_receipt_kinds",
          "repair_task",
          "satisfied",
          "status",
          "receipt_paths"
        ],
        "properties": {
          "obligation_id": { "type": "string" },
          "surface_id": { "type": "string" },
          "path": { "type": "string" },
          "symbol": { "type": "string" },
          "surface_type": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "risk_tags": { "type": "array", "items": { "type": "string" } },
          "rule_ids": { "type": "array", "items": { "type": "string" } },
          "required_lanes": { "type": "array", "items": { "type": "string" } },
          "required_receipt_kinds": { "type": "array", "items": { "type": "string" } },
          "repair_task": { "type": "string" },
          "satisfied": { "type": "boolean" },
          "status": { "type": "string", "enum": ["satisfied", "missing"] },
          "receipt_paths": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "total",
        "satisfied",
        "missing",
        "high_or_critical_missing",
        "changed_surface_count",
        "verdict"
      ],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "satisfied": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 },
        "high_or_critical_missing": { "type": "integer", "minimum": 0 },
        "changed_surface_count": { "type": "integer", "minimum": 0 },
        "verdict": { "type": "string", "enum": ["pass", "review", "block"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
