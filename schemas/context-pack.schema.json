{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/context-pack.schema.json",
  "title": "jankurai context pack",
  "type": "object",
  "required": [
    "schema_version",
    "task",
    "owner",
    "permission_profile",
    "changed_paths",
    "allowed_paths",
    "forbidden_paths",
    "generated_zones",
    "read_first_files",
    "relevant_docs",
    "proof_lanes",
    "commands",
    "likely_rules",
    "scope_decisions",
    "human_approval_required",
    "human_approval_reasons",
    "max_context_files",
    "stop_conditions",
    "residual_risk",
    "token_budget",
    "estimated_tokens",
    "agent",
    "included_files",
    "excluded_files",
    "source_trust_summary",
    "raw_output_policy"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "task": { "type": "string" },
    "owner": { "type": "string" },
    "permission_profile": { "type": "string" },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "allowed_paths": { "type": "array", "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "generated_zones": { "type": "array", "items": { "type": "string" } },
    "read_first_files": { "type": "array", "items": { "type": "string" } },
    "relevant_docs": { "type": "array", "items": { "type": "string" } },
    "proof_lanes": { "type": "array", "items": { "type": "string" } },
    "commands": { "type": "array", "items": { "type": "string" } },
    "likely_rules": { "type": "array", "items": { "type": "string" } },
    "scope_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "owner",
          "owner_route",
          "test_command",
          "proof_lane",
          "generated_zone",
          "generated_source",
          "generated_command",
          "decision",
          "reason"
        ],
        "properties": {
          "path": { "type": "string" },
          "owner": { "type": "string" },
          "owner_route": { "type": "string" },
          "test_command": { "type": "string" },
          "proof_lane": { "type": "string" },
          "generated_zone": { "type": "boolean" },
          "generated_source": { "type": "string" },
          "generated_command": { "type": "string" },
          "decision": {
            "type": "string",
            "enum": ["allowed", "read-only", "human-review"]
          },
          "reason": { "type": "string" }
        }
      }
    },
    "human_approval_required": { "type": "boolean" },
    "human_approval_reasons": { "type": "array", "items": { "type": "string" } },
    "max_context_files": { "type": "integer", "minimum": 1 },
    "stop_conditions": { "type": "array", "items": { "type": "string" } },
    "residual_risk": { "type": "array", "items": { "type": "string" } },
    "token_budget": { "type": "integer", "minimum": 1 },
    "estimated_tokens": { "type": "integer", "minimum": 0 },
    "agent": { "type": "string", "enum": ["codex", "claude", "cursor", "generic"] },
    "included_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "estimated_tokens", "reason", "source_trust"],
        "properties": {
          "path": { "type": "string" },
          "estimated_tokens": { "type": "integer", "minimum": 1 },
          "reason": { "type": "string" },
          "source_trust": {
            "type": "string",
            "enum": [
              "trusted-policy",
              "repo-code",
              "generated-artifact",
              "proof-evidence",
              "docs",
              "untrusted-input"
            ]
          }
        }
      }
    },
    "excluded_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "reason"],
        "properties": {
          "path": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "source_trust_summary": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "raw_output_policy": { "type": "string" }
  }
}
