{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/repair-plan.schema.json",
  "title": "jankurai repair plan",
  "description": "V1 dry-run envelope emitted by jankurai repair-plan.",
  "type": "object",
  "required": [
    "schema_version",
    "source_report",
    "generated_at",
    "target_stack_id",
    "packets",
    "plan_mode",
    "planned_edits",
    "planned_commands",
    "proof_lanes",
    "rollback_guidance",
    "human_approval_requirements"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "source_report": { "type": "string" },
    "generated_at": { "type": "string" },
    "target_stack_id": { "type": "string" },
    "packets": {
      "type": "array",
      "items": { "$ref": "repair-packet.schema.json" }
    },
    "plan_mode": { "const": "dry-run" },
    "planned_edits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "operation",
          "reason",
          "finding_fingerprint",
          "rule_id",
          "apply_strategy",
          "risk_level",
          "repair_eligibility"
        ],
        "properties": {
          "path": { "type": "string" },
          "operation": {
            "enum": [
              "modify",
              "regenerate",
              "review-only",
              "none",
              "append-text",
              "replace-exact",
              "create-file"
            ]
          },
          "reason": { "type": "string" },
          "finding_fingerprint": { "type": "string" },
          "rule_id": { "type": "string" },
          "apply_strategy": {
            "enum": [
              "none",
              "append-text",
              "replace-exact",
              "create-file",
              "review-only",
              "regenerate"
            ]
          },
          "risk_level": { "type": "string" },
          "repair_eligibility": { "type": "string" },
          "match_text": { "type": "string" },
          "replacement_text": { "type": "string" },
          "append_text": { "type": "string" },
          "create_text": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "planned_commands": { "type": "array", "items": { "type": "string" } },
    "proof_lanes": { "type": "array", "items": { "type": "string" } },
    "rollback_guidance": { "type": "array", "items": { "type": "string" } },
    "human_approval_requirements": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
