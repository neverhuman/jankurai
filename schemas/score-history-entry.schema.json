{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/score-history-entry.schema.json",
  "title": "jankurai score history entry",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "auditor_version",
    "generated_at",
    "run_id",
    "branch",
    "commit",
    "dirty_worktree",
    "scope",
    "changed_paths",
    "score",
    "raw_score",
    "finding_count",
    "hard_findings",
    "soft_findings",
    "decision",
    "minimum_score",
    "caps_applied",
    "report_fingerprint",
    "repo_score_json_path",
    "repo_score_md_path"
  ],
  "properties": {
    "schema_version": { "type": "string", "enum": ["1.0.0", "1.1.0"] },
    "standard_version": { "type": ["string", "null"] },
    "auditor_version": { "type": ["string", "null"] },
    "generated_at": { "type": "string" },
    "run_id": { "type": "string" },
    "repo_id": { "type": ["string", "null"] },
    "repo_remote": { "type": ["string", "null"] },
    "branch": { "type": "string" },
    "commit": { "type": "string" },
    "dirty_worktree": { "type": "boolean" },
    "scope": { "type": "string" },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "score": { "type": "integer" },
    "raw_score": { "type": "integer" },
    "finding_count": { "type": "integer", "minimum": 0 },
    "hard_findings": { "type": "integer", "minimum": 0 },
    "soft_findings": { "type": "integer", "minimum": 0 },
    "decision": { "type": "string" },
    "minimum_score": { "type": "integer" },
    "caps_applied": { "type": "array", "items": { "type": "string" } },
    "report_fingerprint": { "type": "string" },
    "input_fingerprint": { "type": ["string", "null"] },
    "policy_fingerprint": { "type": ["string", "null"] },
    "repo_score_json_path": { "type": "string" },
    "repo_score_md_path": { "type": "string" }
  },
  "additionalProperties": false
}
