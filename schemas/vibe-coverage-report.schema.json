{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/vibe-coverage-report.schema.json",
  "title": "jankurai vibe coverage report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "schema_url",
    "command",
    "source_path",
    "tips_path",
    "release",
    "paper_edition",
    "issue_count",
    "source_ref_count",
    "expected_source_row_count",
    "unmapped_source_rows",
    "duplicate_source_refs",
    "missing_source_refs",
    "unexpected_source_refs",
    "coverage_counts",
    "tlr_counts",
    "canonical_group_counts",
    "rule_id_counts",
    "tool_id_counts",
    "priority_counts",
    "detector_status_counts",
    "evidence_status_counts",
    "top_gaps",
    "issues"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "schema_url": { "const": "schemas/vibe-coverage-report.schema.json" },
    "command": { "const": "jankurai vibe coverage" },
    "source_path": { "type": "string" },
    "tips_path": { "type": "string" },
    "release": { "type": "string" },
    "paper_edition": { "type": "string" },
    "issue_count": { "type": "integer", "minimum": 0 },
    "source_ref_count": { "type": "integer", "minimum": 0 },
    "expected_source_row_count": { "type": "integer", "minimum": 0 },
    "unmapped_source_rows": { "type": "integer", "minimum": 0 },
    "duplicate_source_refs": { "type": "array", "items": { "type": "string" } },
    "missing_source_refs": { "type": "array", "items": { "type": "string" } },
    "unexpected_source_refs": { "type": "array", "items": { "type": "string" } },
    "coverage_counts": { "$ref": "#/$defs/countMap" },
    "tlr_counts": { "$ref": "#/$defs/countMap" },
    "canonical_group_counts": { "$ref": "#/$defs/countMap" },
    "rule_id_counts": { "$ref": "#/$defs/countMap" },
    "tool_id_counts": { "$ref": "#/$defs/countMap" },
    "priority_counts": { "$ref": "#/$defs/countMap" },
    "detector_status_counts": { "$ref": "#/$defs/countMap" },
    "evidence_status_counts": { "$ref": "#/$defs/countMap" },
    "top_gaps": { "type": "array", "items": { "$ref": "#/$defs/gap" } },
    "issues": {
      "type": "array",
      "items": { "$ref": "vibe-coverage-source.schema.json#/$defs/issue" }
    }
  },
  "$defs": {
    "countMap": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "gap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "coverage", "priority", "gap", "next_action"],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "coverage": {
          "type": "string",
          "enum": ["detector-backed", "absolute", "partial", "none"]
        },
        "priority": { "type": "string" },
        "gap": { "type": "string" },
        "next_action": { "type": "string" }
      }
    }
  }
}
