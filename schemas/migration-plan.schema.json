{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/migration-plan.schema.json",
  "title": "jankurai migration plan",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "status",
    "generated_at",
    "source_report",
    "target_stack",
    "plan_mode",
    "slices",
    "human_approval_requirements"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "status": { "type": "string" },
    "generated_at": { "type": "string" },
    "source_report": { "type": "string" },
    "target_stack": { "type": "string" },
    "plan_mode": {
      "type": "string",
      "enum": ["dry-run", "apply-preview"]
    },
    "commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "slices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slice_id",
          "owner",
          "allowed_paths",
          "forbidden_paths",
          "contracts",
          "tests",
          "proof_lanes",
          "rollback_notes",
          "status",
          "risk_level",
          "dependency_order",
          "human_approval_required"
        ],
        "properties": {
          "slice_id": { "type": "string" },
          "owner": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["candidate", "ready", "blocked", "do-not-migrate-yet"]
          },
          "risk_level": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"]
          },
          "dependency_order": { "type": "integer", "minimum": 0 },
          "human_approval_required": { "type": "boolean" },
          "allowed_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "forbidden_paths": {
            "type": "array",
            "items": { "type": "string" }
          },
          "contracts": {
            "type": "array",
            "items": { "type": "string" }
          },
          "tests": {
            "type": "array",
            "items": { "type": "string" }
          },
          "proof_lanes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "cutover_notes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rollback_notes": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "human_approval_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
