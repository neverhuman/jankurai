{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/repair-pr-draft.schema.json",
  "title": "jankurai repair pr draft",
  "description": "Dry-run auto-PR draft emitted by jankurai repair.",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "source_plan",
    "generated_at",
    "status",
    "execution_mode",
    "max_risk",
    "branch_name",
    "commit_title",
    "pr_title",
    "pr_body",
    "planned_changed_paths",
    "eligible_packets",
    "blocked_packets",
    "proof_lanes",
    "artifact_links",
    "residual_risk",
    "safety_notes",
    "git_mutation_allowed",
    "github_mutation_allowed"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "repo": { "type": "string" },
    "source_plan": { "type": "string" },
    "source_repair_run": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "enum": ["draft-only", "blocked", "failed"] },
    "execution_mode": { "enum": ["dry-run"] },
    "max_risk": { "enum": ["low", "medium", "high", "critical"] },
    "branch_name": { "type": "string" },
    "commit_title": { "type": "string" },
    "pr_title": { "type": "string" },
    "pr_body": { "type": "string" },
    "planned_changed_paths": { "type": "array", "items": { "type": "string" } },
    "eligible_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_fingerprint",
          "path",
          "rule_id",
          "operation",
          "apply_strategy",
          "risk_level",
          "repair_eligibility"
        ],
        "properties": {
          "finding_fingerprint": { "type": "string" },
          "path": { "type": "string" },
          "rule_id": { "type": "string" },
          "operation": { "type": "string" },
          "apply_strategy": { "type": "string" },
          "risk_level": { "enum": ["low", "medium", "high", "critical"] },
          "repair_eligibility": {
            "enum": ["auto-safe", "agent-assisted", "human-required", "never-auto"]
          }
        },
        "additionalProperties": false
      }
    },
    "blocked_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_fingerprint",
          "path",
          "rule_id",
          "operation",
          "apply_strategy",
          "risk_level",
          "repair_eligibility",
          "reason"
        ],
        "properties": {
          "finding_fingerprint": { "type": "string" },
          "path": { "type": "string" },
          "rule_id": { "type": "string" },
          "operation": { "type": "string" },
          "apply_strategy": { "type": "string" },
          "risk_level": { "enum": ["low", "medium", "high", "critical"] },
          "repair_eligibility": {
            "enum": ["auto-safe", "agent-assisted", "human-required", "never-auto"]
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "proof_lanes": { "type": "array", "items": { "type": "string" } },
    "artifact_links": { "type": "array", "items": { "type": "string" } },
    "residual_risk": { "type": "array", "items": { "type": "string" } },
    "safety_notes": { "type": "array", "items": { "type": "string" } },
    "git_mutation_allowed": { "type": "boolean" },
    "github_mutation_allowed": { "type": "boolean" }
  },
  "additionalProperties": false
}
