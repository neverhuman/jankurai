{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/coverage-audit.schema.json",
  "title": "jankurai coverage audit",
  "type": "object",
  "required": [
    "schema_version",
    "generated_by",
    "repo_root",
    "config_path",
    "strict",
    "changed_from",
    "summary",
    "sources",
    "findings"
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "generated_by": { "const": "jankurai coverage audit" },
    "repo_root": { "type": "string" },
    "config_path": { "type": "string" },
    "strict": { "type": "boolean" },
    "changed_from": { "type": ["string", "null"] },
    "summary": { "$ref": "#/$defs/summary" },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/sourceResult" }
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "summary": {
      "type": "object",
      "required": [
        "status",
        "sources_total",
        "sources_present",
        "sources_missing",
        "hard_findings",
        "soft_findings"
      ],
      "properties": {
        "status": { "type": "string", "enum": ["pass", "warn", "fail", "missing"] },
        "sources_total": { "type": "integer", "minimum": 0 },
        "sources_present": { "type": "integer", "minimum": 0 },
        "sources_missing": { "type": "integer", "minimum": 0 },
        "hard_findings": { "type": "integer", "minimum": 0 },
        "soft_findings": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "sourceResult": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "format",
        "mode",
        "status",
        "artifact_paths",
        "matched_artifact",
        "applies_to",
        "owner",
        "lane",
        "metrics",
        "parser_warnings"
      ],
      "properties": {
        "id": { "type": "string" },
        "kind": { "type": "string" },
        "format": { "type": "string" },
        "mode": { "type": "string" },
        "status": { "type": "string" },
        "artifact_paths": { "type": "array", "items": { "type": "string" } },
        "matched_artifact": { "type": ["string", "null"] },
        "applies_to": { "type": "array", "items": { "type": "string" } },
        "owner": { "type": "string" },
        "lane": { "type": "string" },
        "metrics": {
          "type": "object",
          "additionalProperties": true
        },
        "parser_warnings": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "finding": {
      "type": "object",
      "required": [
        "rule_id",
        "severity",
        "confidence",
        "source_id",
        "kind",
        "artifact",
        "path",
        "line",
        "message",
        "evidence",
        "repair",
        "owner",
        "lane"
      ],
      "properties": {
        "rule_id": { "type": "string" },
        "severity": { "type": "string", "enum": ["critical", "high", "medium", "low", "info"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source_id": { "type": "string" },
        "kind": { "type": "string" },
        "artifact": { "type": "string" },
        "path": { "type": "string" },
        "line": { "type": ["integer", "null"], "minimum": 0 },
        "message": { "type": "string" },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "repair": { "type": "string", "minLength": 1 },
        "owner": { "type": "string" },
        "lane": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
