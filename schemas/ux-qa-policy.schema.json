{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/ux-qa-policy.schema.json",
  "title": "jankurai UX QA policy",
  "description": "Policy for agent/ux-qa.toml (TOML parsed to JSON for validation). Doctor uses the standard TOML parser; @jankurai/ux-qa uses a line-oriented subset—prefer simple key/value and [[routes]] tables.",
  "type": "object",
  "properties": {
    "artifactRoot": { "type": "string" },
    "outputRoot": { "type": "string" },
    "decisionThreshold": { "enum": ["error", "warning"] },
    "readyState": { "enum": ["domcontentloaded", "load", "networkidle"] },
    "timeoutMs": { "type": "integer", "minimum": 1 },
    "storybookUrl": { "type": "string" },
    "requiredStates": { "type": "array", "items": { "enum": ["loading", "empty", "error", "success", "permission-denied"] } },
    "visualBaselineMode": { "enum": ["pass", "review", "block"] },
    "visualBaselineRoot": { "type": "string" },
    "visualDiffRoot": { "type": "string" },
    "baselineOwner": { "type": "string" },
    "baselineApprovedBy": { "type": "string" },
    "baselineApprovedAt": { "type": "string" },
    "baselineApprovalNote": { "type": "string" },
    "stateQueryParam": { "type": "string" },
    "screenshotRequired": { "type": "boolean" },
    "ariaSnapshotRequired": { "type": "boolean" },
    "accessibilityScanRequired": { "type": "boolean" },
    "viewports": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[0-9]+x[0-9]+$" }
    },
    "routes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "url"],
        "properties": {
          "id": { "type": "string" },
          "url": { "type": "string" },
          "storyId": { "type": "string" },
          "states": { "type": "array", "items": { "enum": ["loading", "empty", "error", "success", "permission-denied"] } },
          "visualBaselineMode": { "enum": ["pass", "review", "block"] },
          "baselinePath": { "type": "string" },
          "baselineOwner": { "type": "string" },
          "baselineApprovedBy": { "type": "string" },
          "baselineApprovedAt": { "type": "string" },
          "baselineApprovalNote": { "type": "string" },
          "stateQueryParam": { "type": "string" },
          "viewports": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[0-9]+x[0-9]+$" }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
