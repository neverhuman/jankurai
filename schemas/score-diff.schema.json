{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/score-diff.schema.json",
  "title": "jankurai score diff",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "base_report",
    "head_report",
    "base_score",
    "head_score",
    "score_delta",
    "caps_added",
    "caps_removed",
    "new_findings",
    "resolved_findings",
    "carried_findings",
    "new_high_or_critical",
    "decision"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "const": "jankurai score diff" },
    "base_report": { "type": "string" },
    "head_report": { "type": "string" },
    "base_score": { "type": "integer" },
    "head_score": { "type": "integer" },
    "score_delta": { "type": "integer" },
    "base_raw_score": { "type": "integer" },
    "head_raw_score": { "type": "integer" },
    "raw_score_delta": { "type": "integer" },
    "caps_added": { "type": "array", "items": { "type": "string" } },
    "caps_removed": { "type": "array", "items": { "type": "string" } },
    "new_findings": { "type": "array", "items": { "type": "object" } },
    "resolved_findings": { "type": "array", "items": { "type": "object" } },
    "carried_findings": { "type": "array", "items": { "type": "object" } },
    "new_high_or_critical": { "type": "integer", "minimum": 0 },
    "resolved_high_or_critical": { "type": "integer", "minimum": 0 },
    "decision": { "type": "string", "enum": ["pass", "review", "ratchet_fail"] }
  }
}
