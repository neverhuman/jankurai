{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/proof-plan.schema.json",
  "title": "jankurai proof plan",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "repo_root",
    "git_head",
    "changed_paths",
    "matched_owner_map",
    "matched_test_map",
    "required_lanes",
    "optional_lanes",
    "skipped_lanes",
    "commands",
    "expected_artifacts",
    "risk_notes",
    "human_approval_requirements"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "repo_root": { "type": "string" },
    "git_head": { "type": "string" },
    "base_ref": { "type": "string" },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "matched_owner_map": { "type": "array", "items": { "type": "string" } },
    "matched_test_map": { "type": "array", "items": { "type": "string" } },
    "required_lanes": { "type": "array", "items": { "type": "string" } },
    "optional_lanes": { "type": "array", "items": { "type": "string" } },
    "skipped_lanes": { "type": "array", "items": { "type": "string" } },
    "commands": { "type": "array", "items": { "type": "string" } },
    "expected_artifacts": { "type": "array", "items": { "type": "string" } },
    "risk_notes": { "type": "array", "items": { "type": "string" } },
    "human_approval_requirements": { "type": "array", "items": { "type": "string" } },
    "route_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "changed_path",
          "match_kind",
          "specificity",
          "decision",
          "reason"
        ],
        "properties": {
          "changed_path": { "type": "string" },
          "owner_route": { "type": "string" },
          "test_route": { "type": "string" },
          "lane": { "type": "string" },
          "command": { "type": "string" },
          "match_kind": { "type": "string" },
          "specificity": { "type": "integer", "minimum": 0 },
          "decision": { "type": "string" },
          "reason": { "type": "string" },
          "residual_risk": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "planned_runs": {
      "type": "array",
      "items": { "type": "object", "additionalProperties": true }
    },
    "skipped_lane_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lane", "reason"],
        "properties": {
          "lane": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
