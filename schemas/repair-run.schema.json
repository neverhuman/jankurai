{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/repair-run.schema.json",
  "title": "jankurai repair run",
  "description": "Dry-run, fixture-apply, or real-apply repair execution receipt emitted by jankurai repair.",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "plan",
    "generated_at",
    "status",
    "execution_mode",
    "dry_run",
    "auto_pr_requested",
    "auto_pr_status",
    "max_risk",
    "planned_packets",
    "risk_summary",
    "blocked_packets",
    "applied_edits",
    "skipped_edits",
    "files_written",
    "proof_lanes",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "repo": { "type": "string" },
    "plan": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "enum": ["complete", "blocked", "failed"] },
    "execution_mode": { "enum": ["dry-run", "fixture-apply", "real-apply"] },
    "dry_run": { "type": "boolean" },
    "auto_pr_requested": { "type": "boolean" },
    "auto_pr_status": {
      "enum": [
        "not-requested",
        "eligible-dry-run-only",
        "blocked",
        "prepared",
        "created"
      ]
    },
    "max_risk": { "enum": ["low", "medium", "high", "critical"] },
    "planned_packets": { "type": "integer" },
    "risk_summary": {
      "type": "object",
      "required": ["low", "medium", "high", "critical"],
      "properties": {
        "low": { "type": "integer" },
        "medium": { "type": "integer" },
        "high": { "type": "integer" },
        "critical": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "blocked_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_fingerprint",
          "rule_id",
          "risk_level",
          "repair_eligibility",
          "reason"
        ],
        "properties": {
          "finding_fingerprint": { "type": "string" },
          "rule_id": { "type": "string" },
          "risk_level": { "enum": ["low", "medium", "high", "critical"] },
          "repair_eligibility": {
            "enum": ["auto-safe", "agent-assisted", "human-required", "never-auto"]
          },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "applied_edits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "finding_fingerprint",
          "path",
          "apply_strategy",
          "before_sha256",
          "after_sha256",
          "status"
        ],
        "properties": {
          "finding_fingerprint": { "type": "string" },
          "path": { "type": "string" },
          "apply_strategy": { "type": "string" },
          "before_sha256": { "type": "string" },
          "after_sha256": { "type": "string" },
          "status": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "skipped_edits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["finding_fingerprint", "path", "reason"],
        "properties": {
          "finding_fingerprint": { "type": "string" },
          "path": { "type": "string" },
          "reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "files_written": { "type": "array", "items": { "type": "string" } },
    "proof_evidence_index": { "type": "string" },
    "auto_pr_draft": {
      "type": "object",
      "required": [
        "status",
        "branch_name",
        "commit_title",
        "pr_title",
        "planned_changed_paths",
        "proof_lanes",
        "artifact_links",
        "git_mutation_allowed",
        "github_mutation_allowed"
      ],
      "properties": {
        "status": { "enum": ["draft-only", "blocked", "failed"] },
        "branch_name": { "type": "string" },
        "commit_title": { "type": "string" },
        "pr_title": { "type": "string" },
        "planned_changed_paths": { "type": "array", "items": { "type": "string" } },
        "proof_lanes": { "type": "array", "items": { "type": "string" } },
        "artifact_links": { "type": "array", "items": { "type": "string" } },
        "git_mutation_allowed": { "type": "boolean" },
        "github_mutation_allowed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "git_mutation": {
      "type": "object",
      "required": [
        "status",
        "base_branch",
        "head_branch",
        "base_sha",
        "head_sha",
        "commit_title",
        "files_committed",
        "rollback_command",
        "remote",
        "pushed"
      ],
      "properties": {
        "status": { "enum": ["committed", "rolled-back", "failed"] },
        "base_branch": { "type": "string" },
        "head_branch": { "type": "string" },
        "base_sha": { "type": "string" },
        "head_sha": { "type": "string" },
        "commit_sha": { "type": "string" },
        "commit_title": { "type": "string" },
        "files_committed": { "type": "array", "items": { "type": "string" } },
        "rollback_command": { "type": "string" },
        "remote": { "type": "string" },
        "pushed": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "github_pr": {
      "type": "object",
      "required": ["status", "draft", "remote", "base_branch", "head_branch", "command"],
      "properties": {
        "status": { "enum": ["created", "failed"] },
        "draft": { "type": "boolean" },
        "url": { "type": "string" },
        "remote": { "type": "string" },
        "base_branch": { "type": "string" },
        "head_branch": { "type": "string" },
        "command": { "type": "array", "items": { "type": "string" } },
        "error": { "type": "string" }
      },
      "additionalProperties": false
    },
    "proof_lanes": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
