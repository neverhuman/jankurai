{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/rule-registry.schema.json",
  "title": "jankurai rule registry",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "generated_at",
    "standard_version",
    "auditor_version",
    "rules"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "const": "jankurai rules export" },
    "generated_at": { "type": "string" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "lane", "severity", "status"],
        "properties": {
          "id": { "type": "string", "pattern": "^HLT-[0-9]{3}-[A-Z0-9-]+$" },
          "name": { "type": "string" },
          "category": { "type": "string" },
          "tlr": { "type": "string" },
          "lane": { "type": "string" },
          "docs_url": { "type": "string" },
          "owner_hint": { "type": "string" },
          "evidence_kind": { "type": "string" },
          "severity": { "type": "string" },
          "repairable": { "type": "boolean" },
          "repair_eligibility": { "type": "string" },
          "repair_risk": { "type": "string" },
          "repair_reason": { "type": "string" },
          "status": { "type": "string" },
          "standard_section": { "type": "string" },
          "cap_key": { "type": ["string", "null"] },
          "confidence_policy": { "type": "string" }
        }
      }
    }
  }
}
