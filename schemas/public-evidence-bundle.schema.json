{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/public-evidence-bundle.schema.json",
  "title": "jankurai public evidence bundle",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "repo",
    "standard_version",
    "auditor_version",
    "paper_edition",
    "target_stack_id",
    "public_status",
    "publishable",
    "score",
    "conformance_level",
    "claimed_conformance_level",
    "observed_conformance_level",
    "conformance_decision",
    "conformance_blockers",
    "findings_summary",
    "benchmark_summary",
    "governance",
    "badge",
    "artifacts",
    "attestation",
    "validation_commands"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo": { "type": "string" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "paper_edition": { "type": "string" },
    "target_stack_id": { "type": "string" },
    "public_status": {
      "type": "string",
      "enum": ["publishable", "advisory", "blocked"]
    },
    "publishable": { "type": "boolean" },
    "score": { "type": "integer" },
    "conformance_level": { "type": "string" },
    "claimed_conformance_level": { "type": "string" },
    "observed_conformance_level": { "type": "string" },
    "conformance_decision": { "type": "string" },
    "conformance_blockers": { "type": "array", "items": { "type": "string" } },
    "findings_summary": {
      "type": "object",
      "required": ["critical", "high", "medium", "low"],
      "properties": {
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "low": { "type": "integer" },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "benchmark_summary": {
      "type": "object",
      "required": ["passed", "failed", "inconclusive"],
      "properties": {
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "inconclusive": { "type": "integer" },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "governance": {
      "type": "object",
      "required": ["standard_version", "minimum_score", "fail_on", "advisory_on", "update_channel"],
      "properties": {
        "standard_version": { "type": "string" },
        "minimum_score": { "type": "integer" },
        "fail_on": { "type": "array", "items": { "type": "string" } },
        "advisory_on": { "type": "array", "items": { "type": "string" } },
        "update_channel": { "type": "string" },
        "rfc_path": { "type": "string" }
      },
      "additionalProperties": false
    },
    "badge": {
      "type": "object",
      "required": [
        "schema_version",
        "label",
        "message",
        "color",
        "score",
        "conformance_level",
        "claimed_conformance_level",
        "observed_conformance_level",
        "conformance_decision",
        "standard_version"
      ],
      "properties": {
        "schema_version": { "type": "string" },
        "label": { "type": "string" },
        "message": { "type": "string" },
        "color": {
          "type": "string",
          "enum": ["brightgreen", "green", "yellowgreen", "yellow", "orange", "red", "blue", "lightgrey"]
        },
        "score": { "type": "integer" },
        "conformance_level": { "type": "string" },
        "claimed_conformance_level": { "type": "string" },
        "observed_conformance_level": { "type": "string" },
        "conformance_decision": { "type": "string" },
        "conformance_blockers": { "type": "array", "items": { "type": "string" } },
        "standard_version": { "type": "string" },
        "artifact": { "type": "string" }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "role", "present", "public"],
        "properties": {
          "path": { "type": "string" },
          "role": { "type": "string" },
          "present": { "type": "boolean" },
          "sha256": { "type": "string" },
          "schema": { "type": "string" },
          "public": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "attestation": {
      "type": "object",
      "required": [
        "kind",
        "predicate_type",
        "subject_digest",
        "signature",
        "signing_key_hint",
        "command"
      ],
      "properties": {
        "kind": { "type": "string" },
        "predicate_type": { "type": "string" },
        "subject_digest": { "type": "string" },
        "signature": { "type": "string" },
        "signing_key_hint": { "type": "string" },
        "command": { "type": "string" },
        "git_head": { "type": "string" },
        "build_url": { "type": "string" }
      },
      "additionalProperties": false
    },
    "validation_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blocking_reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
