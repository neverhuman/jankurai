{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/repo-score.schema.json",
  "title": "jankurai repo score",
  "type": "object",
  "required": [
    "report_fingerprint",
    "input_fingerprint",
    "policy_fingerprint",
    "manifest_fingerprints",
    "dirty_worktree",
    "generated_at",
    "schema_url",
    "standard",
    "standard_version",
    "auditor_version",
    "schema_version",
    "paper_edition",
    "target_stack_id",
    "target_stack",
    "claimed_conformance_level",
    "observed_conformance_level",
    "conformance_decision",
    "conformance_blockers",
    "repo",
    "run_id",
    "started_at",
    "elapsed_ms",
    "scope",
    "score",
    "raw_score",
    "decision",
    "git",
    "policy",
    "caps_applied",
    "hard_rules",
    "dimensions",
    "ux_qa",
    "tool_adoption",
    "security_evidence",
    "boundaries",
    "profile_structure",
    "findings",
    "agent_fix_queue"
  ],
  "properties": {
    "report_fingerprint": { "$ref": "#/$defs/sha256" },
    "input_fingerprint": { "$ref": "#/$defs/sha256" },
    "policy_fingerprint": { "$ref": "#/$defs/sha256" },
    "manifest_fingerprints": {
      "type": "object",
      "properties": {
        "owner_map": { "$ref": "#/$defs/sha256" },
        "test_map": { "$ref": "#/$defs/sha256" },
        "generated_zones": { "$ref": "#/$defs/sha256" },
        "boundaries": { "$ref": "#/$defs/sha256" },
        "proof_lanes": { "$ref": "#/$defs/sha256" },
        "standard_version": { "$ref": "#/$defs/sha256" }
      },
      "additionalProperties": false
    },
    "dirty_worktree": { "type": "boolean" },
    "generated_at": { "type": "string" },
    "schema_url": { "const": "schemas/repo-score.schema.json" },
    "standard": { "const": "jankurai" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "schema_version": { "type": "string" },
    "paper_edition": { "type": "string" },
    "target_stack_id": { "type": "string" },
    "target_stack": { "type": "string" },
    "claimed_conformance_level": { "$ref": "#/$defs/conformanceLevel" },
    "observed_conformance_level": { "$ref": "#/$defs/conformanceLevel" },
    "conformance_decision": {
      "type": "string",
      "enum": ["pass", "review", "block", "fail"]
    },
    "conformance_blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "repo": { "type": "string" },
    "run_id": { "type": "string" },
    "started_at": { "type": "string" },
    "elapsed_ms": { "type": "integer", "minimum": 0 },
    "scope": { "$ref": "#/$defs/scope" },
    "score": { "type": "integer" },
    "raw_score": { "type": "integer" },
    "decision": { "$ref": "#/$defs/reportDecision" },
    "git": { "$ref": "#/$defs/gitSummary" },
    "policy": { "$ref": "#/$defs/policySummary" },
    "proof_receipts": {
      "type": "array",
      "items": { "$ref": "proof-receipt.schema.json" }
    },
    "caps_applied": {
      "type": "array",
      "items": { "type": "string" }
    },
    "hard_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/hardRule" }
    },
    "dimensions": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimensionResult" }
    },
    "findings": { "type": "array", "items": { "$ref": "finding.schema.json" } },
    "agent_fix_queue": { "type": "array", "items": { "$ref": "repair-queue.schema.json" } },
    "ux_qa": { "$ref": "#/$defs/uxQaReadiness" },
    "tool_adoption": { "$ref": "#/$defs/toolAdoptionReadiness" },
    "security_evidence": { "$ref": "#/$defs/securityEvidenceReadiness" },
    "boundaries": { "$ref": "#/$defs/boundariesReadiness" },
    "profile_structure": { "$ref": "#/$defs/profileStructureReadiness" },
    "vibe_coverage": { "$ref": "#/$defs/vibeCoverageSummary" },
    "coverage_evidence": { "$ref": "#/$defs/coverageEvidenceSummary" }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "conformanceLevel": {
      "type": "string",
      "enum": ["HL0", "HL1", "HL2", "HL3", "HL4", "HL5"]
    },
    "scope": {
      "type": "object",
      "required": ["mode", "paths"],
      "properties": {
        "mode": { "type": "string" },
        "paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "hardRule": {
      "type": "object",
      "required": ["id", "max_score"],
      "properties": {
        "id": { "type": "string" },
        "max_score": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "dimensionResult": {
      "type": "object",
      "required": ["name", "weight", "score", "weighted_points", "evidence", "notes"],
      "properties": {
        "name": { "type": "string" },
        "weight": { "type": "integer", "minimum": 0 },
        "score": { "type": "integer" },
        "weighted_points": { "type": "number" },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "reportDecision": {
      "type": "object",
      "required": [
        "status",
        "minimum_score",
        "passed",
        "hard_findings",
        "soft_findings"
      ],
      "properties": {
        "status": { "type": "string" },
        "minimum_score": { "type": "integer" },
        "passed": { "type": "boolean" },
        "hard_findings": { "type": "integer", "minimum": 0 },
        "soft_findings": { "type": "integer", "minimum": 0 },
        "ratchet": {
          "type": "object",
          "required": [
            "baseline_score",
            "allowed_drop",
            "passed",
            "score_delta",
            "baseline_report_fingerprint",
            "baseline_input_fingerprint",
            "baseline_policy_fingerprint",
            "new_caps",
            "new_hard_findings",
            "policy_changed"
          ],
          "properties": {
            "baseline_score": { "type": "integer" },
            "allowed_drop": { "type": "integer" },
            "passed": { "type": "boolean" },
            "score_delta": { "type": "integer" },
            "baseline_report_fingerprint": { "$ref": "#/$defs/sha256" },
            "baseline_input_fingerprint": { "$ref": "#/$defs/sha256" },
            "baseline_policy_fingerprint": { "$ref": "#/$defs/sha256" },
            "new_caps": {
              "type": "array",
              "items": { "type": "string" }
            },
            "new_hard_findings": {
              "type": "array",
              "items": { "type": "string" }
            },
            "policy_changed": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "gitSummary": {
      "type": "object",
      "required": ["head", "base", "changed_files", "mode", "dirty_worktree"],
      "properties": {
        "head": { "type": ["string", "null"] },
        "base": { "type": ["string", "null"] },
        "changed_files": { "type": "integer", "minimum": 0 },
        "mode": { "type": "string" },
        "dirty_worktree": { "type": ["boolean", "null"] }
      },
      "additionalProperties": false
    },
    "policySummary": {
      "type": "object",
      "required": ["path", "minimum_score", "fail_on", "advisory_on"],
      "properties": {
        "path": { "type": "string" },
        "minimum_score": { "type": "integer" },
        "fail_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "advisory_on": {
          "type": "array",
          "items": { "type": "string" }
        },
        "mode": { "type": "string" },
        "standard_version": { "type": "string" },
        "auditor_version": { "type": "string" },
        "schema_version": { "type": "string" },
        "paper_edition": { "type": "string" },
        "target_stack": { "type": "string" }
      },
      "additionalProperties": false
    },
    "uxQaReportArtifactSummary": {
      "type": "object",
      "description": "Validated ingest summary for target/jankurai/ux-qa.json (audit only; does not drive score).",
      "required": [
        "path",
        "report_count",
        "worst_decision",
        "total_violations",
        "summary_errors",
        "summary_warnings",
        "reports_missing_required_states",
        "missing_state_names",
        "artifact_counts_by_kind",
        "reports_missing_required_artifacts",
        "missing_artifact_kinds",
        "reports_missing_required_accessibility_artifact",
        "accessibility_violation_total",
        "accessibility_incomplete_total",
        "accessibility_pass_total",
        "artifact_fingerprint_count",
        "visual_baseline_missing",
        "visual_baseline_changed",
        "visual_baseline_review",
        "visual_baseline_block"
      ],
      "properties": {
        "path": { "type": "string" },
        "report_count": { "type": "integer", "minimum": 0 },
        "worst_decision": {
          "type": "string",
          "enum": ["pass", "warn", "review", "block"]
        },
        "total_violations": { "type": "integer", "minimum": 0 },
        "summary_errors": { "type": "integer", "minimum": 0 },
        "summary_warnings": { "type": "integer", "minimum": 0 },
        "reports_missing_required_states": { "type": "integer", "minimum": 0 },
        "missing_state_names": {
          "type": "array",
          "items": { "type": "string" }
        },
        "artifact_counts_by_kind": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "reports_missing_required_artifacts": { "type": "integer", "minimum": 0 },
        "missing_artifact_kinds": {
          "type": "array",
          "items": { "type": "string" }
        },
        "reports_missing_required_accessibility_artifact": {
          "type": "integer",
          "minimum": 0
        },
        "accessibility_violation_total": { "type": "integer", "minimum": 0 },
        "accessibility_incomplete_total": { "type": "integer", "minimum": 0 },
        "accessibility_pass_total": { "type": "integer", "minimum": 0 },
        "artifact_fingerprint_count": { "type": "integer", "minimum": 0 },
        "visual_baseline_missing": { "type": "integer", "minimum": 0 },
        "visual_baseline_changed": { "type": "integer", "minimum": 0 },
        "visual_baseline_review": { "type": "integer", "minimum": 0 },
        "visual_baseline_block": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "uxQaReadiness": {
      "type": "object",
      "required": [
        "web_surface",
        "has_rendered_ux_lane",
        "missing_categories",
        "evidence"
      ],
      "properties": {
        "web_surface": { "type": "boolean" },
        "has_rendered_ux_lane": { "type": "boolean" },
        "missing_categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": true,
        "artifact": { "$ref": "#/$defs/uxQaReportArtifactSummary" }
      },
      "additionalProperties": false
    },
    "toolAdoptionItem": {
      "type": "object",
      "required": [
        "id",
        "category",
        "mode",
        "applicable",
        "status",
        "replaced_tools",
        "evidence",
        "missing",
        "artifact_paths"
      ],
      "properties": {
        "id": { "type": "string" },
        "category": { "type": "string" },
        "mode": {
          "type": "string",
          "enum": ["auto", "required", "advisory", "disabled"]
        },
        "applicable": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": [
            "not_applicable",
            "missing",
            "configured",
            "ci_evidence",
            "artifact_verified"
          ]
        },
        "replaced_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "evidence": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missing": {
          "type": "array",
          "items": { "type": "string" }
        },
        "local_command": { "type": ["string", "null"] },
        "ci_command": { "type": ["string", "null"] },
        "artifact_paths": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "toolAdoptionReadiness": {
      "type": "object",
      "required": [
        "control_plane_present",
        "applicable_count",
        "configured_count",
        "ci_evidence_count",
        "artifact_verified_count",
        "replaced_count",
        "items",
        "evidence",
        "missing"
      ],
      "properties": {
        "control_plane_present": { "type": "boolean" },
        "applicable_count": { "type": "integer", "minimum": 0 },
        "configured_count": { "type": "integer", "minimum": 0 },
        "ci_evidence_count": { "type": "integer", "minimum": 0 },
        "artifact_verified_count": { "type": "integer", "minimum": 0 },
        "replaced_count": { "type": "integer", "minimum": 0 },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolAdoptionItem" }
        },
        "evidence": true,
        "missing": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "securityEvidenceArtifactSummary": {
      "type": "object",
      "description": "Validated ingest summary for target/jankurai/security/evidence.json (audit only; does not drive score).",
      "required": [
        "path",
        "envelope_exit_code",
        "elapsed_ms",
        "wrapper_strict",
        "profile",
        "commands_ran",
        "commands_skipped",
        "commands_failed",
        "required_commands_skipped",
        "required_commands_failed",
        "blocking_commands"
      ],
      "properties": {
        "path": { "type": "string" },
        "envelope_exit_code": { "type": "integer" },
        "elapsed_ms": { "type": "integer", "minimum": 0 },
        "wrapper_strict": { "type": "boolean" },
        "profile": { "type": "string" },
        "commands_ran": { "type": "integer", "minimum": 0 },
        "commands_skipped": { "type": "integer", "minimum": 0 },
        "commands_failed": { "type": "integer", "minimum": 0 },
        "required_commands_skipped": { "type": "integer", "minimum": 0 },
        "required_commands_failed": { "type": "integer", "minimum": 0 },
        "blocking_commands": {
          "type": "array",
          "items": { "type": "string" }
        },
        "generated_at": { "type": "string" },
        "git_head": { "type": "string" }
      },
      "additionalProperties": false
    },
    "securityEvidenceReadiness": {
      "type": "object",
      "properties": {
        "artifact": { "$ref": "#/$defs/securityEvidenceArtifactSummary" }
      },
      "additionalProperties": false
    },
    "boundariesManifestSummary": {
      "type": "object",
      "description": "Validated ingest summary for agent/boundaries.toml (audit only; does not drive score).",
      "required": [
        "path",
        "content_fingerprint",
        "stack_id",
        "adapter_path_count",
        "event_contract_path_count",
        "generated_type_path_count",
        "client_marker_count",
        "streaming_exception_count"
      ],
      "properties": {
        "path": { "type": "string" },
        "content_fingerprint": { "$ref": "#/$defs/sha256" },
        "stack_id": { "type": "string" },
        "stack_version": { "type": "string" },
        "adapter_path_count": { "type": "integer", "minimum": 0 },
        "event_contract_path_count": { "type": "integer", "minimum": 0 },
        "generated_type_path_count": { "type": "integer", "minimum": 0 },
        "client_marker_count": { "type": "integer", "minimum": 0 },
        "streaming_exception_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "boundariesReadiness": {
      "type": "object",
      "properties": {
        "artifact": { "$ref": "#/$defs/boundariesManifestSummary" },
        "reclassifications": {
          "type": "array",
          "items": { "$ref": "#/$defs/boundaryReclassification" }
        }
      },
      "additionalProperties": false
    },
    "profileStructureCell": {
      "type": "object",
      "required": [
        "id",
        "applicable",
        "status",
        "canonical_path",
        "detected_paths",
        "aliases",
        "guidance_status",
        "owner",
        "proof_lane",
        "agent_fix"
      ],
      "properties": {
        "id": { "type": "string" },
        "applicable": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["not_applicable", "canonical", "noncanonical"]
        },
        "canonical_path": { "type": "string" },
        "detected_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "guidance_status": {
          "type": "string",
          "enum": ["not_required", "present", "missing"]
        },
        "owner": { "type": "string" },
        "proof_lane": { "type": "string" },
        "agent_fix": { "type": "string" }
      },
      "additionalProperties": false
    },
    "profileStructureReadiness": {
      "type": "object",
      "required": [
        "applicable_count",
        "canonical_count",
        "noncanonical_count",
        "guidance_missing_count",
        "cells",
        "evidence"
      ],
      "properties": {
        "applicable_count": { "type": "integer", "minimum": 0 },
        "canonical_count": { "type": "integer", "minimum": 0 },
        "noncanonical_count": { "type": "integer", "minimum": 0 },
        "guidance_missing_count": { "type": "integer", "minimum": 0 },
        "cells": {
          "type": "array",
          "items": { "$ref": "#/$defs/profileStructureCell" }
        },
        "evidence": true
      },
      "additionalProperties": false
    },
    "boundaryEvidenceArtifactSummary": {
      "type": "object",
      "required": ["path", "status", "file_count", "check_count"],
      "properties": {
        "path": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["missing_evidence", "invalid", "loaded"]
        },
        "sha256": { "$ref": "#/$defs/sha256" },
        "file_count": { "type": "integer", "minimum": 0 },
        "check_count": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "boundaryReclassification": {
      "type": "object",
      "required": [
        "id",
        "paths",
        "classification",
        "product_surface",
        "runtime_language",
        "status",
        "reclassified_caps",
        "covered_file_count",
        "covered_line_count",
        "covered_files",
        "evidence_artifacts",
        "missing_checks",
        "failed_checks",
        "rerun_command"
      ],
      "properties": {
        "id": { "type": "string" },
        "paths": { "type": "array", "items": { "type": "string" } },
        "classification": { "type": "string" },
        "product_surface": { "type": "boolean" },
        "runtime_language": { "type": "string", "enum": ["python"] },
        "status": {
          "type": "string",
          "enum": ["passed", "missing_evidence", "failed", "invalid", "unsupported"]
        },
        "reclassified_caps": { "type": "array", "items": { "type": "string" } },
        "covered_file_count": { "type": "integer", "minimum": 0 },
        "covered_line_count": { "type": "integer", "minimum": 0 },
        "covered_files": { "type": "array", "items": { "type": "string" } },
        "evidence_artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/boundaryEvidenceArtifactSummary" }
        },
        "missing_checks": { "type": "array", "items": { "type": "string" } },
        "failed_checks": { "type": "array", "items": { "type": "string" } },
        "rerun_command": { "type": "string" }
      },
      "additionalProperties": false
    },
    "vibeCoverageSummary": {
      "type": "object",
      "required": [
        "source_path",
        "issue_count",
        "source_ref_count",
        "unmapped_source_rows",
        "coverage_counts",
        "tlr_counts",
        "priority_counts",
        "top_gaps"
      ],
      "properties": {
        "source_path": { "type": "string" },
        "issue_count": { "type": "integer", "minimum": 0 },
        "source_ref_count": { "type": "integer", "minimum": 0 },
        "unmapped_source_rows": { "type": "integer", "minimum": 0 },
        "coverage_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "tlr_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "priority_counts": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "top_gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "name", "coverage", "priority", "gap", "next_action"],
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "coverage": { "type": "string" },
              "priority": { "type": "string" },
              "gap": { "type": "string" },
              "next_action": { "type": "string" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "coverageEvidenceSummary": {
      "type": "object",
      "required": [
        "artifact",
        "status",
        "sources_total",
        "sources_present",
        "hard_findings",
        "soft_findings"
      ],
      "properties": {
        "artifact": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["pass", "warn", "fail", "missing"]
        },
        "sources_total": { "type": "integer", "minimum": 0 },
        "sources_present": { "type": "integer", "minimum": 0 },
        "hard_findings": { "type": "integer", "minimum": 0 },
        "soft_findings": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  }
}
