{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/cell-registry.schema.json",
  "title": "jankurai cell registry",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "repo",
    "registry_version",
    "generated_at",
    "status",
    "summary",
    "cells",
    "certified_cell_count",
    "candidate_cell_count",
    "candidate_cells",
    "required_sources",
    "proof_lanes",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "repo": { "type": "string" },
    "registry_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "type": "string" },
    "summary": { "type": "string" },
    "cells": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "cell-manifest.schema.json" }
    },
    "certified_cell_count": { "type": "integer" },
    "candidate_cell_count": { "type": "integer" },
    "candidate_cells": {
      "type": "array",
      "items": { "$ref": "#/$defs/registryCell" }
    },
    "required_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "proof_lanes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "registryCell": {
      "type": "object",
      "required": [
        "cell_id",
        "owner",
        "category",
        "lifecycle",
        "certification_status",
        "source_paths",
        "proof_lanes",
        "upgrade_notes"
      ],
      "properties": {
        "cell_id": { "type": "string" },
        "owner": { "type": "string" },
        "category": { "type": "string" },
        "lifecycle": { "type": "string" },
        "certification_status": { "type": "string" },
        "source_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "proof_lanes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "upgrade_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
