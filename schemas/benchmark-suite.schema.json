{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/benchmark-suite.schema.json",
  "title": "jankurai benchmark suite",
  "type": "object",
  "required": [
    "schema_version",
    "suite_id",
    "purpose",
    "fixtures",
    "tasks"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "suite_id": { "type": "string" },
    "purpose": { "type": "string" },
    "fixtures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "fixture_id",
          "path",
          "kind",
          "expected_findings",
          "expected_score_range"
        ],
        "properties": {
          "fixture_id": { "type": "string" },
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "expected_findings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_score_range": {
            "type": "object",
            "required": ["minimum", "maximum"],
            "properties": {
              "minimum": { "type": "integer" },
              "maximum": { "type": "integer" }
            },
            "additionalProperties": false
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "description",
          "fixture_ids",
          "commands",
          "expected_metrics"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "description": { "type": "string" },
          "fixture_ids": {
            "type": "array",
            "items": { "type": "string" }
          },
          "commands": {
            "type": "array",
            "items": { "type": "string" }
          },
          "expected_metrics": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "expected_results": {
      "type": "array",
      "items": { "type": "string" }
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
