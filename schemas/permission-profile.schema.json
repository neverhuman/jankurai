{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/permission-profile.schema.json",
  "title": "jankurai permission profile",
  "type": "object",
  "required": [
    "name",
    "scope",
    "allowed_commands",
    "forbidden_commands",
    "approval_required"
  ],
  "properties": {
    "name": {
      "enum": [
        "read-only",
        "docs-only",
        "code-edit",
        "generated-regeneration",
        "security-investigation",
        "release"
      ]
    },
    "scope": { "type": "string" },
    "allowed_commands": { "type": "array", "items": { "type": "string" } },
    "forbidden_commands": { "type": "array", "items": { "type": "string" } },
    "approval_required": { "type": "boolean" },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
