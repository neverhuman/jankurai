{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/score-history-export.schema.json",
  "title": "jankurai score history export",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "history",
    "window",
    "source",
    "history_bytes",
    "sample_count",
    "rows",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "const": "jankurai history export" },
    "history": { "type": "string" },
    "window": { "type": "integer", "minimum": 0 },
    "source": {
      "type": "string",
      "enum": ["auto", "local", "mirror"]
    },
    "repo_id": { "type": ["string", "null"] },
    "history_bytes": { "type": "integer", "minimum": 0 },
    "sample_count": { "type": "integer", "minimum": 0 },
    "latest_generated_at": { "type": ["string", "null"] },
    "latest_commit": { "type": ["string", "null"] },
    "rows": {
      "type": "array",
      "items": { "$ref": "score-history-entry.schema.json" }
    },
    "summary": {
      "type": "object",
      "required": [
        "source",
        "history_bytes",
        "sample_count",
        "high_or_critical_latest",
        "decision"
      ],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["auto", "local", "mirror"]
        },
        "repo_id": { "type": ["string", "null"] },
        "history_bytes": { "type": "integer", "minimum": 0 },
        "sample_count": { "type": "integer", "minimum": 0 },
        "latest_generated_at": { "type": ["string", "null"] },
        "latest_commit": { "type": ["string", "null"] },
        "first_score": { "type": ["integer", "null"] },
        "latest_score": { "type": ["integer", "null"] },
        "score_delta": { "type": ["integer", "null"] },
        "best_score": { "type": ["integer", "null"] },
        "worst_score": { "type": ["integer", "null"] },
        "latest_decision": { "type": ["string", "null"] },
        "high_or_critical_latest": { "type": "integer", "minimum": 0 },
        "decision": { "type": "string", "enum": ["pass", "review"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
