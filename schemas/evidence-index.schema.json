{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/evidence-index.schema.json",
  "title": "jankurai proof evidence index",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "repo_root",
    "git_head",
    "plan_path",
    "receipt_dir",
    "log_dir",
    "commands",
    "receipts",
    "logs",
    "failed_receipts",
    "skipped_lanes",
    "risk_notes",
    "human_approval_requirements",
    "changed_paths"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "git_head": { "type": "string" },
    "plan_path": { "type": "string" },
    "plan_digest": { "type": "string" },
    "manifest_fingerprints": {
      "type": "object",
      "properties": {
        "owner_map": { "type": "string" },
        "test_map": { "type": "string" },
        "generated_zones": { "type": "string" },
        "boundaries": { "type": "string" },
        "proof_lanes": { "type": "string" },
        "standard_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "receipt_dir": { "type": "string" },
    "log_dir": { "type": "string" },
    "commands": { "type": "array", "items": { "type": "string" } },
    "receipts": { "type": "array", "items": { "type": "string" } },
    "command_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "log_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "artifact_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "receipt_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "logs": { "type": "array", "items": { "type": "string" } },
    "coverage_verdicts": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "rule_id": { "type": "string" },
              "status": { "type": "string" }
            },
            "required": ["rule_id", "status"],
            "additionalProperties": false
          },
          { "type": "string" }
        ]
      }
    },
    "failed_receipts": { "type": "array", "items": { "type": "string" } },
    "skipped_lanes": { "type": "array", "items": { "type": "string" } },
    "risk_notes": { "type": "array", "items": { "type": "string" } },
    "human_approval_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "ux_qa_report_path": { "type": "string" },
    "ux_qa_report_digest": { "type": "string" },
    "security_evidence_path": { "type": "string" },
    "repo_score_json_path": { "type": "string" },
    "coverage_audit_path": { "type": "string" },
    "sarif_path": { "type": "string" },
    "github_step_summary_path": { "type": "string" },
    "repair_queue_jsonl_path": { "type": "string" },
    "boundaries_manifest_path": { "type": "string" }
  },
  "additionalProperties": true
}
