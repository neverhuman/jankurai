{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/repair-packet.schema.json",
  "title": "jankurai repair packet",
  "type": "object",
  "required": [
    "finding_fingerprint",
    "finding_path",
    "rule_id",
    "check_id",
    "severity",
    "owner",
    "lane",
    "problem",
    "why",
    "permission_profile",
    "allowed_paths",
    "forbidden_paths",
    "expected_patch_shape",
    "required_proof",
    "stop_conditions",
    "repair_eligibility",
    "risk_level",
    "eligibility_reason",
    "human_review_required",
    "rollback_guidance"
  ],
  "properties": {
    "finding_fingerprint": { "type": "string" },
    "finding_path": { "type": "string" },
    "rule_id": { "type": "string" },
    "check_id": { "type": "string" },
    "severity": { "type": "string" },
    "owner": { "type": "string" },
    "lane": { "type": "string" },
    "problem": { "type": "string" },
    "why": { "type": "string" },
    "permission_profile": { "type": "string" },
    "allowed_paths": { "type": "array", "items": { "type": "string" } },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "expected_patch_shape": { "type": "string" },
    "required_proof": { "type": "array", "items": { "type": "string" } },
    "stop_conditions": { "type": "array", "items": { "type": "string" } },
    "repair_eligibility": {
      "enum": ["auto-safe", "agent-assisted", "never-auto"]
    },
    "risk_level": {
      "enum": ["low", "medium", "high", "critical"]
    },
    "eligibility_reason": { "type": "string" },
    "human_review_required": { "type": "boolean" },
    "rollback_guidance": { "type": "string" }
  }
}
