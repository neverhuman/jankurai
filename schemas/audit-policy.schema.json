{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/audit-policy.schema.json",
  "title": "jankurai audit policy",
  "type": "object",
  "required": ["minimum_score"],
  "properties": {
    "minimum_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "fail_on": { "type": "array", "items": { "type": "string" } },
    "advisory_on": { "type": "array", "items": { "type": "string" } },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "schema_version": { "type": "string" },
    "paper_edition": { "type": "string" },
    "target_stack": { "type": "string" },
    "history": {
      "type": "object",
      "properties": {
        "max_rows": { "type": "integer", "minimum": 1 },
        "max_bytes": { "type": "integer", "minimum": 1 },
        "dedupe": { "type": "string" },
        "mirror_env": { "type": "string" },
        "mirror_required": { "type": "boolean" },
        "mirror_max_rows": { "type": "integer", "minimum": 1 }
      }
    },
    "scan": {
      "type": "object",
      "properties": {
        "text_capture_chars": { "type": "integer", "minimum": 1 },
        "max_capture_chars": { "type": "integer", "minimum": 1 },
        "excluded_paths": { "type": "array", "items": { "type": "string" } },
        "extra_excluded_paths": { "type": "array", "items": { "type": "string" } },
        "extra_excluded_globs": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
