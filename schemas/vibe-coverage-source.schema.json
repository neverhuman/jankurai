{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/vibe-coverage-source.schema.json",
  "title": "jankurai vibe coverage source",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release", "paper_edition", "source_count", "issues"],
  "properties": {
    "schema_version": { "const": "1.7.0" },
    "release": { "type": "string" },
    "paper_edition": { "type": "string" },
    "source_count": { "type": "integer", "minimum": 0 },
    "issues": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/issue" }
    }
  },
  "$defs": {
    "stringArray": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "issue": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "aliases",
        "tlr",
        "category",
        "canonical_group",
        "source_issue_kind",
        "detector_status",
        "evidence_status",
        "reviewed",
        "description",
        "recommended_control",
        "source_refs",
        "coverage",
        "coverage_reason",
        "rule_ids",
        "tool_ids",
        "proof_lanes",
        "artifacts",
        "gap",
        "next_action",
        "owner",
        "priority"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^VCOV-TIP[1-5]-R[0-9]{3}$" },
        "name": { "type": "string", "minLength": 1 },
        "aliases": { "$ref": "#/$defs/stringArray" },
        "tlr": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "canonical_group": {
          "type": "string",
          "enum": [
            "authz-data-isolation",
            "input-boundary",
            "secrets-privacy",
            "dependency-supply-chain",
            "agent-tool-supply",
            "prod-destructive-release",
            "cost-budget",
            "test-verification",
            "requirements-context",
            "architecture-entropy",
            "performance-concurrency",
            "observability-repair",
            "ux-a11y",
            "human-review-governance"
          ]
        },
        "source_issue_kind": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "detector_status": {
          "type": "string",
          "enum": ["detector-backed", "control-family", "governance-control"]
        },
        "evidence_status": {
          "type": "string",
          "enum": ["audit-evidence", "partial-evidence", "accepted-risk"]
        },
        "reviewed": { "const": true },
        "description": { "type": "string", "minLength": 1 },
        "recommended_control": { "type": "string", "minLength": 1 },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "pattern": "^tip[1-5]:[1-9][0-9]*$" }
        },
        "coverage": {
          "type": "string",
          "enum": ["detector-backed", "absolute", "partial", "none"]
        },
        "coverage_reason": { "type": "string", "minLength": 1 },
        "rule_ids": { "$ref": "#/$defs/stringArray" },
        "tool_ids": { "$ref": "#/$defs/stringArray" },
        "proof_lanes": { "$ref": "#/$defs/stringArray" },
        "artifacts": { "$ref": "#/$defs/stringArray" },
        "gap": { "type": "string", "minLength": 1 },
        "next_action": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "priority": { "type": "string", "enum": ["P0", "P1", "P2"] }
      }
    }
  }
}
