{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/postmortem.schema.json",
  "title": "jankurai postmortem record",
  "type": "object",
  "required": [
    "schema_version",
    "postmortem_id",
    "title",
    "owner",
    "failure_mode",
    "severity",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "postmortem_id": { "type": "string" },
    "title": { "type": "string" },
    "owner": { "type": "string" },
    "failure_mode": {
      "type": "string",
      "enum": [
        "aspirational-spec",
        "env-prerequisite",
        "interop-runtime",
        "equivalence-gap",
        "cutover-rollback",
        "perf-regression"
      ]
    },
    "severity": { "type": "string" },
    "blocker_type": {
      "type": "string",
      "enum": [
        "aspirational-spec",
        "env-prerequisite",
        "interop-runtime",
        "equivalence-gap",
        "cutover-rollback",
        "perf-regression"
      ]
    },
    "summary": { "type": "string" },
    "evidence": {
      "type": "array",
      "items": { "type": "string" }
    },
    "actions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": { "type": "string" },
    "recorded_at": { "type": "string" }
  },
  "additionalProperties": false
}
