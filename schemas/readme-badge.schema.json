{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Jankurai README Badge",
  "type": "object",
  "required": [
    "schema_version",
    "standard",
    "source_report",
    "source_badge_fingerprint",
    "score",
    "decision",
    "passed",
    "findings",
    "hard_findings",
    "soft_findings",
    "caps",
    "badge_svg",
    "markdown"
  ],
  "properties": {
    "schema_version": { "type": "string", "minLength": 1 },
    "standard": { "const": "jankurai" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "source_report": { "type": "string", "minLength": 1 },
    "source_badge_fingerprint": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "raw_score": { "type": "integer", "minimum": 0 },
    "minimum_score": { "type": "integer", "minimum": 0 },
    "decision": { "type": "string", "minLength": 1 },
    "passed": { "type": "boolean" },
    "findings": { "type": "integer", "minimum": 0 },
    "hard_findings": { "type": "integer", "minimum": 0 },
    "soft_findings": { "type": "integer", "minimum": 0 },
    "caps": { "type": "integer", "minimum": 0 },
    "conformance_level": { "type": "string" },
    "badge_svg": { "type": "string", "minLength": 1 },
    "readme": { "type": "string" },
    "markdown": { "type": "string" }
  }
}
