{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/merge-witness.schema.json",
  "title": "jankurai merge witness",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "auditor_version",
    "command",
    "generated_at",
    "repo",
    "git",
    "changed_paths",
    "route_decisions",
    "generated_zone_touches",
    "required_lanes",
    "available_proof_receipts",
    "proofbind",
    "missing_evidence",
    "current_score",
    "current_raw_score",
    "claimed_conformance_level",
    "observed_conformance_level",
    "conformance_decision",
    "conformance_blockers",
    "caps_applied",
    "caps_added",
    "new_findings",
    "resolved_findings",
    "carried_findings",
    "decision",
    "next_repair"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "command": { "const": "jankurai witness" },
    "generated_at": { "type": "string" },
    "repo": { "type": "string" },
    "git": {
      "type": "object",
      "required": ["base_ref", "base", "head", "dirty_worktree"],
      "properties": {
        "base_ref": { "type": ["string", "null"] },
        "base": { "type": ["string", "null"] },
        "head": { "type": ["string", "null"] },
        "dirty_worktree": { "type": "boolean" }
      }
    },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "route_decisions": { "type": "array", "items": { "type": "object" } },
    "generated_zone_touches": { "type": "array", "items": { "type": "object" } },
    "required_lanes": { "type": "array", "items": { "type": "string" } },
    "available_proof_receipts": { "type": "array", "items": { "type": "object" } },
    "proofbind": {
      "type": "object",
      "required": [
        "changed_surface_count",
        "satisfied_obligation_count",
        "missing_obligation_count",
        "verdict"
      ],
      "properties": {
        "changed_surface_count": { "type": "integer", "minimum": 0 },
        "satisfied_obligation_count": { "type": "integer", "minimum": 0 },
        "missing_obligation_count": { "type": "integer", "minimum": 0 },
        "verdict": { "type": "string" }
      },
      "additionalProperties": false
    },
    "missing_evidence": { "type": "array", "items": { "type": "string" } },
    "current_score": { "type": "integer" },
    "current_raw_score": { "type": "integer" },
    "baseline_score": { "type": ["integer", "null"] },
    "score_delta": { "type": ["integer", "null"] },
    "claimed_conformance_level": { "$ref": "#/$defs/conformanceLevel" },
    "observed_conformance_level": { "$ref": "#/$defs/conformanceLevel" },
    "conformance_decision": {
      "type": "string",
      "enum": ["pass", "review", "block", "ratchet_fail", "release_fail"]
    },
    "conformance_blockers": { "type": "array", "items": { "type": "string" } },
    "caps_applied": { "type": "array", "items": { "type": "string" } },
    "caps_added": { "type": "array", "items": { "type": "string" } },
    "new_findings": { "type": "array", "items": { "type": "object" } },
    "resolved_findings": { "type": "array", "items": { "type": "object" } },
    "carried_findings": { "type": "array", "items": { "type": "object" } },
    "decision": {
      "type": "string",
      "enum": ["pass", "review", "block", "ratchet_fail", "release_fail"]
    },
    "next_repair": { "type": "array", "items": { "type": "string" } }
  },
  "$defs": {
    "conformanceLevel": {
      "type": "string",
      "enum": ["HL0", "HL1", "HL2", "HL3", "HL4", "HL5"]
    }
  },
  "additionalProperties": false
}
