{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/copy-code.schema.json",
  "title": "jankurai copy-code report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_by",
    "generated_at",
    "repo",
    "auditor_version",
    "status",
    "policy",
    "summary",
    "classes",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_by": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo": { "type": "string" },
    "auditor_version": { "type": "string" },
    "status": { "type": "string", "enum": ["pass", "review", "fail"] },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "active_source_only",
        "include_tests",
        "min_lines",
        "min_tokens",
        "max_findings",
        "strict",
        "excluded_roots",
        "warning_only_roots"
      ],
      "properties": {
        "active_source_only": { "type": "boolean" },
        "include_tests": { "type": "boolean" },
        "min_lines": { "type": "integer", "minimum": 1 },
        "min_tokens": { "type": "integer", "minimum": 1 },
        "max_findings": { "type": "integer", "minimum": 1 },
        "strict": { "type": "boolean" },
        "excluded_roots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warning_only_roots": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files_scanned",
        "files_considered",
        "active_files",
        "exact_file_classes",
        "hard_classes",
        "warning_classes",
        "hard_instances",
        "warning_instances",
        "duplicate_lines",
        "duplicate_tokens",
        "duplicate_bytes",
        "total_redundant_lines",
        "total_redundant_tokens",
        "total_redundant_bytes"
      ],
      "properties": {
        "files_scanned": { "type": "integer", "minimum": 0 },
        "files_considered": { "type": "integer", "minimum": 0 },
        "active_files": { "type": "integer", "minimum": 0 },
        "exact_file_classes": { "type": "integer", "minimum": 0 },
        "hard_classes": { "type": "integer", "minimum": 0 },
        "warning_classes": { "type": "integer", "minimum": 0 },
        "hard_instances": { "type": "integer", "minimum": 0 },
        "warning_instances": { "type": "integer", "minimum": 0 },
        "duplicate_lines": { "type": "integer", "minimum": 0 },
        "duplicate_tokens": { "type": "integer", "minimum": 0 },
        "duplicate_bytes": { "type": "integer", "minimum": 0 },
        "total_redundant_lines": { "type": "integer", "minimum": 0 },
        "total_redundant_tokens": { "type": "integer", "minimum": 0 },
        "total_redundant_bytes": { "type": "integer", "minimum": 0 }
      }
    },
    "classes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "kind",
          "severity",
          "confidence",
          "language",
          "duplicate_lines",
          "duplicate_tokens",
          "duplicate_bytes",
          "instance_count",
          "total_redundant_lines",
          "total_redundant_tokens",
          "total_redundant_bytes",
          "effective_severity",
          "hard_fail",
          "fingerprint",
          "reason",
          "recommended_action",
          "instances"
        ],
        "properties": {
          "id": { "type": "string" },
          "kind": {
            "type": "string",
            "enum": [
              "exact_file",
              "exact_unit_same_name",
              "exact_unit_different_name",
              "token_block"
            ]
          },
          "severity": { "type": "string", "enum": ["hard", "warning"] },
          "confidence": { "type": "string" },
          "language": { "type": "string" },
          "unit_name": { "type": ["string", "null"] },
          "duplicate_lines": { "type": "integer", "minimum": 0 },
          "duplicate_tokens": { "type": "integer", "minimum": 0 },
          "duplicate_bytes": { "type": "integer", "minimum": 0 },
          "instance_count": { "type": "integer", "minimum": 2 },
          "total_redundant_lines": { "type": "integer", "minimum": 0 },
          "total_redundant_tokens": { "type": "integer", "minimum": 0 },
          "total_redundant_bytes": { "type": "integer", "minimum": 0 },
          "effective_severity": { "type": "string", "enum": ["hard", "warning"] },
          "hard_fail": { "type": "boolean" },
          "fingerprint": { "type": "string" },
          "reason": { "type": "string" },
          "recommended_action": { "type": "string" },
          "suppressed": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "by": { "type": "string", "enum": ["allowlist"] },
              "owner": { "type": ["string", "null"] },
              "reason": { "type": ["string", "null"] },
              "expires": { "type": ["string", "null"] }
            }
          },
          "instances": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path",
                "language",
                "start_line",
                "end_line"
              ],
              "properties": {
                "path": { "type": "string" },
                "language": { "type": "string" },
                "start_line": { "type": "integer", "minimum": 1 },
                "end_line": { "type": "integer", "minimum": 1 },
                "unit_name": { "type": ["string", "null"] }
              }
            }
          }
        }
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
