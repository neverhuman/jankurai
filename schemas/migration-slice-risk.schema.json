{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/migration-slice-risk.schema.json",
  "title": "jankurai migration slice risk",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "status",
    "decision",
    "repo",
    "plan",
    "slice_id",
    "slice_status",
    "risk_level",
    "check_env",
    "signals_total",
    "critical_signals",
    "high_signals",
    "medium_signals",
    "low_signals",
    "env_checks",
    "signals",
    "recommendations"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "status": { "type": "string" },
    "decision": { "type": "string", "enum": ["pass", "review", "block"] },
    "repo": { "type": "string" },
    "plan": { "type": "string" },
    "slice_id": { "type": "string" },
    "slice_status": { "type": "string" },
    "risk_level": { "type": "string" },
    "check_env": { "type": "boolean" },
    "signals_total": { "type": "integer", "minimum": 0 },
    "critical_signals": { "type": "integer", "minimum": 0 },
    "high_signals": { "type": "integer", "minimum": 0 },
    "medium_signals": { "type": "integer", "minimum": 0 },
    "low_signals": { "type": "integer", "minimum": 0 },
    "env_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "present"],
        "properties": {
          "name": { "type": "string" },
          "present": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "severity", "decision", "evidence", "recommendation"],
        "properties": {
          "kind": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "decision": {
            "type": "string",
            "enum": ["block", "review", "pass"]
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "recommendation": { "type": "string" },
          "path": { "type": "string" },
          "line": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
