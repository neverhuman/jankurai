{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/exception-expiry-report.schema.json",
  "title": "jankurai exception expiry report",
  "description": "Advisory report for dated exception expiry tracking.",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "generated_at",
    "status",
    "exception_root",
    "warning_days",
    "total_exceptions",
    "expired_count",
    "expiring_soon_count",
    "invalid_count",
    "exceptions",
    "proof_requirements",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "repo": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "enum": ["complete", "blocked", "failed"] },
    "exception_root": { "type": "string" },
    "warning_days": { "type": "integer" },
    "total_exceptions": { "type": "integer", "minimum": 0 },
    "expired_count": { "type": "integer", "minimum": 0 },
    "expiring_soon_count": { "type": "integer", "minimum": 0 },
    "invalid_count": { "type": "integer", "minimum": 0 },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "code",
          "owner",
          "reason",
          "expires",
          "migration_plan",
          "proof_lane",
          "status",
          "repair_options",
          "notes"
        ],
        "properties": {
          "path": { "type": "string" },
          "code": { "type": "string" },
          "owner": { "type": "string" },
          "reason": { "type": "string" },
          "expires": { "type": "string" },
          "migration_plan": { "type": "string" },
          "proof_lane": { "type": "string" },
          "status": {
            "enum": ["current", "expiring-soon", "expired", "invalid"]
          },
          "days_until_expiry": { "type": "integer" },
          "repair_options": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "array", "items": { "type": "string" } }
        },
        "additionalProperties": false
      }
    },
    "proof_requirements": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
