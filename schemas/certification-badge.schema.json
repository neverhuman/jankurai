{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/certification-badge.schema.json",
  "title": "jankurai certification badge",
  "type": "object",
  "required": [
    "schema_version",
    "label",
    "message",
    "color",
    "score",
    "conformance_level",
    "claimed_conformance_level",
    "observed_conformance_level",
    "conformance_decision",
    "standard_version"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "label": { "type": "string" },
    "message": { "type": "string" },
    "color": {
      "type": "string",
      "enum": ["brightgreen", "green", "yellowgreen", "yellow", "orange", "red", "blue", "lightgrey"]
    },
    "score": { "type": "integer" },
    "conformance_level": { "type": "string" },
    "claimed_conformance_level": { "type": "string" },
    "observed_conformance_level": { "type": "string" },
    "conformance_decision": { "type": "string" },
    "conformance_blockers": { "type": "array", "items": { "type": "string" } },
    "standard_version": { "type": "string" },
    "artifact": { "type": "string" }
  },
  "additionalProperties": false
}
