{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/standard-version.schema.json",
  "title": "jankurai standard version manifest",
  "type": "object",
  "required": ["standard", "standard_version"],
  "properties": {
    "standard": { "type": "string" },
    "standard_version": { "type": "string" },
    "paper_edition": { "type": "string" },
    "auditor_version": { "type": "string" },
    "schema_version": { "type": "string" },
    "target_stack": { "type": "string" },
    "published": { "type": "string" },
    "artifact": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "version_field", "version"],
        "properties": {
          "id": { "type": "string" },
          "path": { "type": "string" },
          "kind": { "type": "string" },
          "version_field": { "type": "string" },
          "version": { "type": "string" },
          "source": { "type": "string" },
          "command": { "type": "string" },
          "generated": { "type": "boolean" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
