{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/test-map.schema.json",
  "title": "jankurai test map",
  "type": "object",
  "required": ["workspace", "tests"],
  "properties": {
    "workspace": { "type": "string" },
    "tests": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["command"],
        "properties": {
          "command": { "type": "string" },
          "purpose": { "type": "string" },
          "lane": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
