{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/optimization-report.schema.json",
  "title": "jankurai optimization report",
  "description": "Advisory optimization report emitted by jankurai optimize.",
  "type": "object",
  "required": [
    "schema_version",
    "repo",
    "generated_at",
    "status",
    "mode",
    "target_stack_id",
    "context_size_before_bytes",
    "context_size_after_bytes",
    "estimated_tokens_before",
    "estimated_tokens_after",
    "context_files",
    "benchmark_summary",
    "findings",
    "proof_requirements",
    "notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "repo": { "type": "string" },
    "generated_at": { "type": "string" },
    "status": { "enum": ["complete", "blocked", "failed"] },
    "mode": {
      "enum": ["all", "token", "performance", "dependency", "dead-code"]
    },
    "target_stack_id": { "type": "string" },
    "context_size_before_bytes": { "type": "integer", "minimum": 0 },
    "context_size_after_bytes": { "type": "integer", "minimum": 0 },
    "estimated_tokens_before": { "type": "integer", "minimum": 0 },
    "estimated_tokens_after": { "type": "integer", "minimum": 0 },
    "context_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "bytes", "duplicate_bytes", "duplicate_lines"],
        "properties": {
          "path": { "type": "string" },
          "bytes": { "type": "integer", "minimum": 0 },
          "duplicate_bytes": { "type": "integer", "minimum": 0 },
          "duplicate_lines": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "benchmark_summary": {
      "type": "object",
      "required": ["passed", "failed", "inconclusive"],
      "properties": {
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "inconclusive": { "type": "integer" },
        "notes": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "subject",
          "path",
          "signal",
          "recommended_action",
          "proof_requirement",
          "risk_level"
        ],
        "properties": {
          "kind": {
            "enum": ["token", "performance", "dependency", "dead-code"]
          },
          "subject": { "type": "string" },
          "path": { "type": "string" },
          "signal": { "type": "string" },
          "recommended_action": { "type": "string" },
          "proof_requirement": { "type": "string" },
          "risk_level": { "enum": ["low", "medium", "high", "critical"] }
        },
        "additionalProperties": false
      }
    },
    "proof_requirements": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
