{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/migration-report.schema.json",
  "title": "jankurai migration report",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "status",
    "generated_at",
    "source_root",
    "source_stack",
    "target_stack",
    "liability_score",
    "liability_breakdown",
    "inventory",
    "module_inventory",
    "contract_evidence",
    "recommended_slice_order",
    "required_proof_lanes",
    "rollback_cutover_notes"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "status": { "type": "string" },
    "generated_at": { "type": "string" },
    "source_root": { "type": "string" },
    "source_stack": { "type": "string" },
    "target_stack": { "type": "string" },
    "liability_score": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "liability_breakdown": {
      "type": "object",
      "required": ["total", "dimensions"],
      "properties": {
        "total": { "type": "integer", "minimum": 0, "maximum": 100 },
        "dimensions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "score", "weight", "evidence"],
            "properties": {
              "name": { "type": "string" },
              "score": { "type": "integer", "minimum": 0, "maximum": 100 },
              "weight": { "type": "number", "minimum": 0, "maximum": 1 },
              "evidence": { "type": "array", "items": { "type": "string" } }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "inventory": {
      "type": "object",
      "required": ["languages", "frameworks", "db_clients", "test_frameworks", "package_managers", "ci_systems", "api_surfaces", "contract_evidence"],
      "properties": {
        "languages": { "type": "array", "items": { "$ref": "#/$defs/detectedItem" } },
        "frameworks": { "type": "array", "items": { "$ref": "#/$defs/detectedItem" } },
        "db_clients": { "type": "array", "items": { "$ref": "#/$defs/detectedItem" } },
        "test_frameworks": { "type": "array", "items": { "$ref": "#/$defs/detectedItem" } },
        "package_managers": { "type": "array", "items": { "$ref": "#/$defs/detectedItem" } },
        "ci_systems": { "type": "array", "items": { "$ref": "#/$defs/detectedItem" } },
        "api_surfaces": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["framework", "evidence"],
            "properties": {
              "framework": { "type": "string" },
              "evidence": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "contract_evidence": { "type": "array", "items": { "$ref": "#/$defs/contractEvidence" } }
      },
      "additionalProperties": false
    },
    "module_inventory": {
      "type": "array",
      "items": { "type": "string" }
    },
    "owner_guesses": { "type": "array", "items": { "type": "string" } },
    "external_boundaries": { "type": "array", "items": { "type": "string" } },
    "db_surfaces": { "type": "array", "items": { "type": "string" } },
    "api_surfaces": { "type": "array", "items": { "type": "string" } },
    "duplicate_logic": { "type": "array", "items": { "type": "string" } },
    "high_risk_areas": { "type": "array", "items": { "type": "string" } },
    "missing_tests": { "type": "array", "items": { "type": "string" } },
    "strangler_candidates": { "type": "array", "items": { "type": "string" } },
    "contract_evidence": { "type": "array", "items": { "$ref": "#/$defs/contractEvidence" } },
    "recommended_slice_order": { "type": "array", "items": { "type": "string" } },
    "required_proof_lanes": { "type": "array", "items": { "type": "string" } },
    "rollback_cutover_notes": { "type": "array", "items": { "type": "string" } },
    "unknowns": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false,
  "$defs": {
    "detectedItem": {
      "type": "object",
      "required": ["name", "evidence", "confidence"],
      "properties": {
        "name": { "type": "string" },
        "evidence": { "type": "string" },
        "confidence": { "enum": ["high", "medium", "low"] }
      },
      "additionalProperties": false
    },
    "contractEvidence": {
      "type": "object",
      "required": ["kind", "path", "status"],
      "properties": {
        "kind": { "type": "string" },
        "path": { "type": "string" },
        "status": { "enum": ["detected", "draft", "missing"] }
      },
      "additionalProperties": false
    }
  }
}
