{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/kickoff.schema.json",
  "title": "jankurai kickoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "command",
    "generated_at",
    "repo",
    "intent",
    "agent",
    "changed_paths",
    "read_first",
    "route_decisions",
    "generated_zone_touches",
    "ownership_boundaries",
    "forbidden_paths",
    "proof_lanes",
    "clarifying_questions",
    "implementation_steps",
    "parallel_packets",
    "stop_conditions",
    "expected_receipts",
    "next_commands"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo": { "type": "string" },
    "intent": { "type": "string" },
    "agent": { "type": "string", "enum": ["codex", "claude", "cursor", "generic"] },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "read_first": { "type": "array", "items": { "type": "string" } },
    "route_decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "owner",
          "owner_route",
          "test_command",
          "proof_lane",
          "generated_zone",
          "generated_source",
          "generated_command",
          "decision",
          "reason"
        ],
        "properties": {
          "path": { "type": "string" },
          "owner": { "type": "string" },
          "owner_route": { "type": "string" },
          "test_command": { "type": "string" },
          "proof_lane": { "type": "string" },
          "generated_zone": { "type": "boolean" },
          "generated_source": { "type": "string" },
          "generated_command": { "type": "string" },
          "decision": {
            "type": "string",
            "enum": ["allowed", "read-only", "human-review"]
          },
          "reason": { "type": "string" }
        }
      }
    },
    "generated_zone_touches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "zone", "source", "command", "read_only", "reason"],
        "properties": {
          "path": { "type": "string" },
          "zone": { "type": "string" },
          "source": { "type": "string" },
          "command": { "type": "string" },
          "read_only": { "type": "boolean" },
          "reason": { "type": "string" }
        }
      }
    },
    "ownership_boundaries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "owner",
          "paths",
          "owner_routes",
          "test_commands",
          "proof_lanes",
          "write_policy",
          "reason"
        ],
        "properties": {
          "owner": { "type": "string" },
          "paths": { "type": "array", "items": { "type": "string" } },
          "owner_routes": { "type": "array", "items": { "type": "string" } },
          "test_commands": { "type": "array", "items": { "type": "string" } },
          "proof_lanes": { "type": "array", "items": { "type": "string" } },
          "write_policy": { "type": "string" },
          "reason": { "type": "string" }
        }
      }
    },
    "forbidden_paths": { "type": "array", "items": { "type": "string" } },
    "proof_lanes": { "type": "array", "items": { "type": "string" } },
    "clarifying_questions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "question", "reason", "suggested_paths", "blocking"],
        "properties": {
          "id": { "type": "string" },
          "question": { "type": "string" },
          "reason": { "type": "string" },
          "suggested_paths": { "type": "array", "items": { "type": "string" } },
          "blocking": { "type": "boolean" }
        }
      }
    },
    "implementation_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["order", "title", "files", "commands", "notes"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "title": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "commands": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "string" }
        }
      }
    },
    "parallel_packets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "paths",
          "owner",
          "proof_lane",
          "commands",
          "expected_receipts",
          "stop_conditions",
          "reason"
        ],
        "properties": {
          "name": { "type": "string" },
          "paths": { "type": "array", "items": { "type": "string" } },
          "owner": { "type": "string" },
          "proof_lane": { "type": "string" },
          "commands": { "type": "array", "items": { "type": "string" } },
          "expected_receipts": { "type": "array", "items": { "type": "string" } },
          "stop_conditions": { "type": "array", "items": { "type": "string" } },
          "reason": { "type": "string" }
        }
      }
    },
    "stop_conditions": { "type": "array", "items": { "type": "string" } },
    "expected_receipts": { "type": "array", "items": { "type": "string" } },
    "next_commands": { "type": "array", "items": { "type": "string" } }
  }
}
