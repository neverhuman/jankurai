{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/proof-verification.schema.json",
  "title": "jankurai proof verification envelope",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "generated_at",
    "repo_root",
    "plan_path",
    "evidence_index_path",
    "plan_digest",
    "manifest_fingerprints",
    "verdict"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo_root": { "type": "string" },
    "plan_path": { "type": "string" },
    "evidence_index_path": { "type": "string" },
    "plan_digest": { "type": "string" },
    "manifest_fingerprints": {
      "type": "object",
      "properties": {
        "owner_map": { "type": "string" },
        "test_map": { "type": "string" },
        "generated_zones": { "type": "string" },
        "boundaries": { "type": "string" },
        "proof_lanes": { "type": "string" },
        "standard_version": { "type": "string" }
      },
      "additionalProperties": false
    },
    "command_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "log_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "receipt_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "artifact_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "coverage_verdicts": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "rule_id": { "type": "string" },
              "status": { "type": "string" }
            },
            "required": ["rule_id", "status"],
            "additionalProperties": false
          },
          { "type": "string" }
        ]
      }
    },
    "verdict": {
      "enum": ["pass", "fail", "blocked", "stale", "incomplete", "advisory"]
    },
    "issues": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
