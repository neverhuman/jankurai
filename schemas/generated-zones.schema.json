{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/generated-zones.schema.json",
  "title": "jankurai generated zones manifest",
  "type": "object",
  "required": ["zone"],
  "properties": {
    "zone": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "source", "command", "read_only"],
        "properties": {
          "path": { "type": "string" },
          "source": { "type": "string" },
          "command": { "type": "string" },
          "read_only": { "type": "boolean" },
          "write_policy": {
            "type": "string",
            "enum": ["generator_only", "auditor_output", "lockfile", "reviewed_manual"]
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
