{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/doctor-receipt.schema.json",
  "title": "jankurai doctor receipt",
  "type": "object",
  "required": ["action", "created_at", "diagnostics"],
  "properties": {
    "action": { "type": "string" },
    "created_at": { "type": "integer" },
    "diagnostics": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["check_id", "severity", "path", "message"],
        "properties": {
          "check_id": { "type": "string" },
          "severity": { "type": "string" },
          "path": { "type": "string" },
          "message": { "type": "string" },
          "kind": {
            "enum": [
              "file-missing",
              "schema",
              "policy",
              "tool",
              "freshness",
              "receipt",
              "workflow",
              "lockfile",
              "export",
              "other"
            ]
          },
          "environment_sensitive": { "type": "boolean" },
          "strictly_blocking": { "type": "boolean" },
          "common_fixes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
