{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/cell-manifest.schema.json",
  "title": "jankurai cell manifest",
  "type": "object",
  "required": [
    "cell_id",
    "version",
    "category",
    "lifecycle",
    "supported_profiles",
    "dependencies",
    "source_paths",
    "generated_paths",
    "contract_paths",
    "migration_paths",
    "ui_routes",
    "proof_lanes",
    "proof_commands",
    "security_assumptions",
    "observability_events",
    "docs",
    "upgrade_notes",
    "rollback_notes",
    "certification_evidence",
    "install_strategy",
    "conflict_policy",
    "certification_status"
  ],
  "properties": {
    "cell_id": { "type": "string" },
    "version": { "type": "string" },
    "category": { "type": "string" },
    "lifecycle": {
      "type": "string",
      "enum": ["draft", "experimental", "certified", "deprecated"]
    },
    "supported_profiles": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dependencies": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "generated_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contract_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "migration_paths": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ui_routes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "proof_lanes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "proof_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "security_assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "observability_events": {
      "type": "array",
      "items": { "type": "string" }
    },
    "docs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "upgrade_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "rollback_notes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "certification_evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "path", "required", "status"],
        "properties": {
          "kind": { "type": "string" },
          "path": { "type": "string" },
          "required": { "type": "boolean" },
          "status": {
            "type": "string",
            "enum": ["present", "missing", "review-required"]
          }
        },
        "additionalProperties": false
      }
    },
    "install_strategy": {
      "type": "string",
      "enum": ["dry-run-plan", "template-copy", "manual"]
    },
    "conflict_policy": {
      "type": "string",
      "enum": ["never-overwrite", "review-required"]
    },
    "certification_status": {
      "type": "string",
      "enum": ["not-certified", "candidate", "certified", "revoked"]
    }
  },
  "additionalProperties": false
}
