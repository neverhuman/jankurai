{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/proof-receipt.schema.json",
  "title": "jankurai proof receipt",
  "type": "object",
  "required": ["lane", "command", "exit_code", "elapsed_ms", "artifacts"],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "receipt_id": { "type": "string" },
    "lane": { "type": "string" },
    "command": { "type": "string" },
    "exit_code": { "type": "integer" },
    "elapsed_ms": { "type": "integer", "minimum": 0 },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "owner": { "type": "string" },
    "skipped_reason": { "type": "string" },
    "residual_risk": { "type": "array", "items": { "type": "string" } },
    "log_path": { "type": "string" },
    "receipt_path": { "type": "string" },
    "generated_at": { "type": "string" },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "repo": { "type": "string" },
    "repo_root": { "type": "string" },
    "git_head": { "type": "string" },
    "dirty_worktree": { "type": "boolean" },
    "run_id": { "type": "string" },
    "plan_path": { "type": "string" },
    "plan_digest": { "type": "string" },
    "command_digest": { "type": "string" },
    "log_sha256": { "type": "string" },
    "artifact_digests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "sha256"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "rules_covered": {
      "type": "array",
      "items": {
        "anyOf": [
          {
            "type": "object",
            "properties": {
              "rule_id": { "type": "string" },
              "status": { "type": "string" }
            },
            "required": ["rule_id", "status"],
            "additionalProperties": false
          },
          { "type": "string" }
        ]
      }
    },
    "retryable": { "type": "boolean" },
    "stdout_stderr_bytes": { "type": "integer", "minimum": 0 },
    "extensions": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
