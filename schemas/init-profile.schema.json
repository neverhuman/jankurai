{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/init-profile.schema.json",
  "title": "jankurai init profile manifest",
  "type": "object",
  "required": [
    "id",
    "displayName",
    "targetStackId",
    "generatedPaths",
    "requiredLanes",
    "optionalLanes",
    "agentAdapters",
    "ciTemplates",
    "docs",
    "securityControls",
    "uxControls",
    "contractSystem",
    "dbPolicy",
    "validationCommands"
  ],
  "properties": {
    "id": { "type": "string" },
    "displayName": { "type": "string" },
    "targetStackId": { "type": "string" },
    "generatedPaths": { "type": "array", "items": { "type": "string" } },
    "requiredLanes": { "type": "array", "items": { "type": "string" } },
    "optionalLanes": { "type": "array", "items": { "type": "string" } },
    "agentAdapters": { "type": "array", "items": { "type": "string" } },
    "ciTemplates": { "type": "array", "items": { "type": "string" } },
    "docs": { "type": "array", "items": { "type": "string" } },
    "securityControls": { "type": "array", "items": { "type": "string" } },
    "uxControls": { "type": "array", "items": { "type": "string" } },
    "contractSystem": { "type": "array", "items": { "type": "string" } },
    "dbPolicy": { "type": "array", "items": { "type": "string" } },
    "validationCommands": { "type": "array", "items": { "type": "string" } },
    "mergePolicy": {
      "type": "object",
      "description": "Optional brownfield behavior for existing generatedPaths. When present, unspecified existing paths are kept unchanged; when omitted, legacy suffix inference is used for profile-file compatibility.",
      "additionalProperties": {
        "type": "string",
        "enum": [
          "merge-json",
          "merge-toml",
          "merge-lines",
          "merge-marker",
          "keep-existing"
        ]
      }
    }
  }
}
