{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/benchmark-report.schema.json",
  "title": "jankurai benchmark report",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "suite_id",
    "repo",
    "target_stack_id",
    "results",
    "summary"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "runner_version": { "type": "string" },
    "suite_id": { "type": "string" },
    "repo": { "type": "string" },
    "target_stack_id": { "type": "string" },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "fixture_id",
          "status",
          "metrics",
          "evidence"
        ],
        "properties": {
          "task_id": { "type": "string" },
          "fixture_id": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "inconclusive"]
          },
          "metrics": {
            "type": "object",
            "properties": {
              "token_usage": { "type": "number" },
              "wrong_file_edits": { "type": "number" },
              "time_to_first_correct_patch_ms": { "type": "number" },
              "proof_correctness": { "type": "number", "minimum": 0, "maximum": 1 },
              "regression_rate": { "type": "number" },
              "human_review_burden": { "type": "number" }
            },
            "additionalProperties": false
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["passed", "failed", "inconclusive"],
      "properties": {
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "inconclusive": { "type": "integer" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "limitations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "reproducibility_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
