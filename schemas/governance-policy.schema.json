{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/governance-policy.schema.json",
  "title": "jankurai governance policy",
  "type": "object",
  "required": [
    "schema_version",
    "standard_version",
    "effective_at",
    "minimum_score",
    "fail_on",
    "advisory_on",
    "update_channel",
    "rule_change_policy",
    "deprecation_policy",
    "exception_policy",
    "security_advisory_policy"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "standard_version": { "type": "string" },
    "effective_at": { "type": "string" },
    "minimum_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "fail_on": {
      "type": "array",
      "items": { "type": "string" }
    },
    "advisory_on": {
      "type": "array",
      "items": { "type": "string" }
    },
    "update_channel": {
      "type": "string",
      "enum": ["draft", "beta", "stable", "lts"]
    },
    "rule_change_policy": {
      "type": "object",
      "required": ["version_bump", "migration_notes_required"],
      "properties": {
        "version_bump": { "type": "string" },
        "migration_notes_required": { "type": "boolean" },
        "reviewers": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "deprecation_policy": {
      "type": "object",
      "required": ["notice_period_days", "removal_requires"],
      "properties": {
        "notice_period_days": { "type": "integer" },
        "supported_versions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "removal_requires": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "exception_policy": {
      "type": "object",
      "required": ["timebox_days", "owner_required", "proof_required"],
      "properties": {
        "timebox_days": { "type": "integer" },
        "owner_required": { "type": "boolean" },
        "proof_required": { "type": "boolean" },
        "rfc_required": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "security_advisory_policy": {
      "type": "object",
      "required": ["severity_threshold", "response_sla_days"],
      "properties": {
        "severity_threshold": { "type": "string" },
        "response_sla_days": { "type": "integer" },
        "patch_channels": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "rfc_path": { "type": "string" }
  },
  "additionalProperties": false
}
