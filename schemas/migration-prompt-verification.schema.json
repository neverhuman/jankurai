{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/migration-prompt-verification.schema.json",
  "title": "jankurai migration prompt verification",
  "type": "object",
  "required": [
    "schema_version",
    "command",
    "status",
    "decision",
    "repo",
    "document",
    "claims_total",
    "claims_verified",
    "claims_invalid",
    "claims_review",
    "claims"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "command": { "type": "string" },
    "status": { "type": "string" },
    "decision": { "type": "string", "enum": ["pass", "review", "fail"] },
    "repo": { "type": "string" },
    "document": { "type": "string" },
    "claims_total": { "type": "integer", "minimum": 0 },
    "claims_verified": { "type": "integer", "minimum": 0 },
    "claims_invalid": { "type": "integer", "minimum": 0 },
    "claims_review": { "type": "integer", "minimum": 0 },
    "claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_type", "claim", "decision", "evidence"],
        "properties": {
          "claim_type": {
            "type": "string",
            "enum": ["path-line", "module-symbol", "class", "llm-call"]
          },
          "claim": { "type": "string" },
          "decision": {
            "type": "string",
            "enum": ["verified", "invalid", "review"]
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          },
          "note": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
