{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/tool-adoption.schema.json",
  "title": "jankurai tool adoption policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "tools"],
  "properties": {
    "schema_version": { "type": "string" },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "mode"],
        "properties": {
          "id": { "type": "string" },
          "mode": {
            "type": "string",
            "enum": ["auto", "required", "advisory", "disabled"]
          },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
