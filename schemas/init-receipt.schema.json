{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/init-receipt.schema.json",
  "title": "jankurai init receipt",
  "type": "object",
  "required": ["action", "created_at", "actions"],
  "properties": {
    "action": { "type": "string" },
    "created_at": { "type": "integer" },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
