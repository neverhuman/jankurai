{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/certification.schema.json",
  "title": "jankurai certification",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "repo",
    "standard_version",
    "auditor_version",
    "paper_edition",
    "target_stack_id",
    "score",
    "conformance_level",
    "caps",
    "findings_summary",
    "proof_receipt_index",
    "security_receipt_index",
    "ux_receipt_index",
    "contract_db_receipt_index"
  ],
  "properties": {
    "schema_version": { "type": "string" },
    "generated_at": { "type": "string" },
    "repo": { "type": "string" },
    "standard_version": { "type": "string" },
    "auditor_version": { "type": "string" },
    "paper_edition": { "type": "string" },
    "target_stack_id": { "type": "string" },
    "score": { "type": "integer" },
    "conformance_level": {
      "type": "string"
    },
    "caps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "findings_summary": {
      "type": "object",
      "required": ["critical", "high", "medium", "low"],
      "properties": {
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "low": { "type": "integer" },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "proof_receipt_index": {
      "type": "array",
      "items": { "type": "string" }
    },
    "security_receipt_index": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ux_receipt_index": {
      "type": "array",
      "items": { "type": "string" }
    },
    "contract_db_receipt_index": {
      "type": "array",
      "items": { "type": "string" }
    },
    "exceptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provenance": {
      "type": "object",
      "properties": {
        "signature": { "type": "string" },
        "attestation": { "type": "string" },
        "build_url": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
