{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jankurai.dev/schemas/owner-map.schema.json",
  "title": "jankurai owner map",
  "type": "object",
  "required": ["workspace", "owners"],
  "properties": {
    "workspace": { "type": "string" },
    "owners": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          { "type": "string" },
          {
            "type": "object",
            "required": ["owner_id"],
            "properties": {
              "owner_id": { "type": "string" },
              "risk_tier": { "type": "string" },
              "default_lanes": { "type": "array", "items": { "type": "string" } },
              "allowed_dependencies": { "type": "array", "items": { "type": "string" } },
              "reviewers": { "type": "array", "items": { "type": "string" } },
              "docs": { "type": "array", "items": { "type": "string" } },
              "exception_policy": { "type": "string" }
            },
            "additionalProperties": false
          }
        ]
      }
    }
  },
  "additionalProperties": false
}
