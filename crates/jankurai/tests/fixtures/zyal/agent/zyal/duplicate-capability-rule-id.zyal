<<<ZYAL v1:daemon id=duplicate-capability-rule-id>>>
version: v1
intent: daemon
confirm: RUN_FOREVER
job:
  name: "Duplicate capability rule id"
  objective: "Should fail because capability rule ids repeat."
stop:
  all:
    - git_clean:
        allow_untracked: false
capabilities:
  rules:
    - id: lease-one
      tool: shell
      command_regex: "git status"
    - id: lease-one
      tool: shell
      command_regex: "git diff"
<<<END_ZYAL id=duplicate-capability-rule-id>>>
ZYAL_ARM RUN_FOREVER id=duplicate-capability-rule-id
